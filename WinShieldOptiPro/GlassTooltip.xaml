<Window x:Class="WinShieldOptiPro.GlassTooltip"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="GlassTooltip" WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Width="200" Height="80" ShowInTaskbar="False" Topmost="True">
    <Grid>
        <!-- 毛玻璃背景 -->
        <Border Background="#CC1E1E1E" CornerRadius="8" BorderThickness="1" BorderBrush="#00BFFF">
            <Border.Effect>
                <DropShadowEffect Color="#00BFFF" BlurRadius="15" Opacity="0.5"/>
            </Border.Effect>
        </Border>

        <!-- 内容 -->
        <Grid Margin="10">
            <TextBlock x:Name="TooltipText" Text="提示信息" Foreground="#FFFFFF" FontSize="12" TextWrapping="Wrap" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</Window>
