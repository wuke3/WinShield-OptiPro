<Window x:Class="WinShieldOptiPro.TrayPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:effects="clr-namespace:System.Windows.Media.Effects;assembly=PresentationCore"
        xmlns:local="clr-namespace:WinShieldOptiPro"
        mc:Ignorable="d"
        Title="TrayPopup" WindowStyle="None" AllowsTransparency="True" Background="Transparent" Width="300" Height="400"
        WindowStartupLocation="Manual"
        MouseLeave="Window_MouseLeave">
    <Grid>
        <!-- 毛玻璃背景 -->
        <Border Background="#80121212" CornerRadius="12" BorderThickness="1" BorderBrush="#00BFFF">
            <Border.Effect>
                <effects:BlurEffect Radius="10"/>
            </Border.Effect>
        </Border>
        
        <!-- 内容网格 -->
        <Grid Margin="20">
            <!-- 顶部核心状态 -->
            <Grid HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,20,0,0">
                <!-- 3D防护盾图标 -->
                <Grid Width="60" Height="60">
                    <Ellipse Width="60" Height="60" Fill="#00BFFF" Opacity="0.3"/>
                    <Path Data="M30,10 L10,30 L30,50 L50,30 Z" Fill="#00BFFF" Stroke="#FFFFFF" StrokeThickness="2"/>
                    <Path Data="M30,15 L20,25 L30,35 L40,25 Z" Fill="#FFFFFF" Opacity="0.8"/>
                    <Grid.RenderTransform>
                        <RotateTransform x:Name="ShieldRotateTransform" Angle="0" CenterX="30" CenterY="30"/>
                    </Grid.RenderTransform>
                </Grid>
                <!-- 系统状态 -->
                <TextBlock x:Name="SystemStatusText" Text="系统健康度: 100%" FontSize="14" Foreground="#FFFFFF" HorizontalAlignment="Center" Margin="0,70,0,0"/>
                <TextBlock x:Name="DiskStatusText" Text="C盘: 充足" FontSize="12" Foreground="#888888" HorizontalAlignment="Center" Margin="0,90,0,0"/>
            </Grid>
            
            <!-- 中部快捷功能区 -->
            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="0,130,0,0">
                <Button x:Name="QuickCleanButton" Content="一键清理" Width="200" Height="50" Background="#00BFFF" Foreground="#FFFFFF" Margin="0,0,0,10" Click="QuickCleanButton_Click">
                    <Button.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </TransformGroup>
                    </Button.RenderTransform>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8" BorderThickness="2" BorderBrush="Transparent">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="RenderTransform">
                                                    <Setter.Value>
                                                        <TransformGroup>
                                                            <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                                        </TransformGroup>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="BorderBrush" Value="#FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="SystemOptimizeButton" Content="一键优化" Width="200" Height="50" Background="#00BFFF" Foreground="#FFFFFF" Margin="0,0,0,10" Click="SystemOptimizeButton_Click">
                    <Button.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </TransformGroup>
                    </Button.RenderTransform>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8" BorderThickness="2" BorderBrush="Transparent">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="RenderTransform">
                                                    <Setter.Value>
                                                        <TransformGroup>
                                                            <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                                        </TransformGroup>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="BorderBrush" Value="#FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="MemoryOptimizeButton" Content="内存加速" Width="200" Height="50" Background="#00BFFF" Foreground="#FFFFFF" Margin="0,0,0,10" Click="MemoryOptimizeButton_Click">
                    <Button.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </TransformGroup>
                    </Button.RenderTransform>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8" BorderThickness="2" BorderBrush="Transparent">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="RenderTransform">
                                                    <Setter.Value>
                                                        <TransformGroup>
                                                            <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                                        </TransformGroup>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="BorderBrush" Value="#FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="FullScanButton" Content="全盘查杀" Width="200" Height="50" Background="#00BFFF" Foreground="#FFFFFF" Click="FullScanButton_Click">
                    <Button.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </TransformGroup>
                    </Button.RenderTransform>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8" BorderThickness="2" BorderBrush="Transparent">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="RenderTransform">
                                                    <Setter.Value>
                                                        <TransformGroup>
                                                            <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                                        </TransformGroup>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="BorderBrush" Value="#FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
            
            <!-- 底部快捷入口 -->
            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="0,350,0,0">
                <Button x:Name="OpenMainWindowButton" Content="打开主界面" Width="150" Height="35" Background="#2A2A2A" Foreground="#FFFFFF" Margin="0,0,0,10" Click="OpenMainWindowButton_Click"/>
                <Grid HorizontalAlignment="Center">
                    <TextBlock Text="开机自启" FontSize="12" Foreground="#888888" VerticalAlignment="Center"/>
                    <!-- 3D拨动式开关 -->
                    <ToggleButton x:Name="StartupToggle" Width="60" Height="30" Margin="70,0,0,0" Click="StartupToggle_Click">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border Background="{TemplateBinding Background}" CornerRadius="15" BorderThickness="2" BorderBrush="#444444">
                                    <Ellipse x:Name="SwitchThumb" Width="20" Height="20" Fill="#FFFFFF" HorizontalAlignment="Left" Margin="3,3,0,3">
                                        <Ellipse.RenderTransform>
                                            <TranslateTransform X="0"/>
                                        </Ellipse.RenderTransform>
                                    </Ellipse>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="SwitchThumb" Property="RenderTransform">
                                            <Setter.Value>
                                                <TranslateTransform X="30"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Background" Value="#00BFFF"/>
                                    </Trigger>
                                    <Trigger Property="IsChecked" Value="False">
                                        <Setter TargetName="SwitchThumb" Property="RenderTransform">
                                            <Setter.Value>
                                                <TranslateTransform X="0"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Background" Value="#444444"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>
                </Grid>
                <Button x:Name="ExitButton" Content="退出软件" Width="150" Height="35" Background="#444444" Foreground="#FFFFFF" Margin="0,10,0,0" Click="ExitButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>