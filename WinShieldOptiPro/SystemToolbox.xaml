<UserControl x:Class="WinShieldOptiPro.SystemToolbox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WinShieldOptiPro"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000">
    <Grid Background="#121212">
        <!-- 标题 -->
        <TextBlock Text="实用系统工具箱" FontSize="24" FontWeight="Bold" Foreground="#00BFFF" Margin="20,20,0,0"/>
        
        <!-- 标签页 -->
        <TabControl Margin="20,60,20,40" Background="#1E1E1E" BorderBrush="#2A2A2A" TabStripPlacement="Top">
            <!-- 系统核心管控 -->
            <TabItem Header="系统核心管控" Foreground="#FFFFFF" Background="#2A2A2A">
                <Grid Margin="20">
                    <TextBlock Text="Windows更新管控" FontSize="16" FontWeight="Bold" Foreground="#00BFFF" Margin="0,20,0,0"/>
                    <StackPanel Margin="0,60,0,0">
                        <Button Content="开启自动更新" Width="150" Height="40" Background="#00BFFF" Foreground="#FFFFFF" Margin="0,0,10,10" Click="EnableWindowsUpdate_Click"/>
                        <Button Content="关闭自动更新" Width="150" Height="40" Background="#2A2A2A" Foreground="#FFFFFF" Margin="0,0,10,10" Click="DisableWindowsUpdate_Click"/>
                        <Button Content="暂停更新7天" Width="150" Height="40" Background="#2A2A2A" Foreground="#FFFFFF" Margin="0,0,10,10" Click="PauseWindowsUpdate7Days_Click"/>
                        <Button Content="暂停更新15天" Width="150" Height="40" Background="#2A2A2A" Foreground="#FFFFFF" Margin="0,0,10,10" Click="PauseWindowsUpdate15Days_Click"/>
                        <Button Content="暂停更新30天" Width="150" Height="40" Background="#2A2A2A" Foreground="#FFFFFF" Margin="0,0,10,10" Click="PauseWindowsUpdate30Days_Click"/>
                    </StackPanel>
                    
                    <TextBlock Text="Defender安全软件管控" FontSize="16" FontWeight="Bold" Foreground="#00BFFF" Margin="300,20,0,0"/>
                    <StackPanel Margin="300,60,0,0">
                        <Button Content="开启实时防护" Width="150" Height="40" Background="#00BFFF" Foreground="#FFFFFF" Margin="0,0,10,10" Click="EnableDefender_Click"/>
                        <Button Content="关闭实时防护" Width="150" Height="40" Background="#2A2A2A" Foreground="#FFFFFF" Margin="0,0,10,10" Click="DisableDefender_Click"/>
                        <Button Content="开启后台扫描" Width="150" Height="40" Background="#2A2A2A" Foreground="#FFFFFF" Margin="0,0,10,10" Click="EnableDefenderScan_Click"/>
                        <Button Content="关闭后台扫描" Width="150" Height="40" Background="#2A2A2A" Foreground="#FFFFFF" Margin="0,0,10,10" Click="DisableDefenderScan_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>
            
            <!-- 网络修复工具 -->
            <TabItem Header="网络修复工具" Foreground="#FFFFFF" Background="#2A2A2A">
                <Grid Margin="20">
                    <TextBlock Text="断网急救" FontSize="16" FontWeight="Bold" Foreground="#00BFFF" Margin="0,20,0,0"/>
                    <Button Content="一键修复网络" Width="200" Height="50" Background="#00BFFF" Foreground="#FFFFFF" FontSize="14" FontWeight="Bold" Margin="0,60,0,10" Click="FixNetwork_Click"/>
                    <TextBlock x:Name="NetworkFixResultText" Text="" FontSize="14" Foreground="#888888" Margin="0,120,0,0"/>
                    
                    <TextBlock Text="Hosts文件修改" FontSize="16" FontWeight="Bold" Foreground="#00BFFF" Margin="300,20,0,0"/>
                    <TextBox x:Name="HostsFileTextBox" Width="400" Height="200" Background="#2A2A2A" Foreground="#FFFFFF" BorderBrush="#2A2A2A" Margin="300,60,0,0" TextWrapping="Wrap" AcceptsReturn="True"/>
                    <Button Content="保存Hosts" Width="100" Height="30" Background="#00BFFF" Foreground="#FFFFFF" Margin="300,270,0,0" Click="SaveHosts_Click"/>
                    <Button Content="备份Hosts" Width="100" Height="30" Background="#2A2A2A" Foreground="#FFFFFF" Margin="410,270,0,0" Click="BackupHosts_Click"/>
                    <Button Content="恢复默认" Width="100" Height="30" Background="#2A2A2A" Foreground="#FFFFFF" Margin="520,270,0,0" Click="RestoreDefaultHosts_Click"/>
                </Grid>
            </TabItem>
            
            <!-- 系统校准工具 -->
            <TabItem Header="系统校准工具" Foreground="#FFFFFF" Background="#2A2A2A">
                <Grid Margin="20">
                    <TextBlock Text="系统时间校准" FontSize="16" FontWeight="Bold" Foreground="#00BFFF" Margin="0,20,0,0"/>
                    <TextBlock x:Name="CurrentTimeText" Text="当前时间: " FontSize="14" Foreground="#FFFFFF" Margin="0,60,0,0"/>
                    <Button Content="一键同步标准时间" Width="200" Height="40" Background="#00BFFF" Foreground="#FFFFFF" Margin="0,100,0,0" Click="SyncTime_Click"/>
                    <TextBlock x:Name="TimeSyncResultText" Text="" FontSize="14" Foreground="#888888" Margin="0,150,0,0"/>
                </Grid>
            </TabItem>
            
            <!-- 安全实用工具 -->
            <TabItem Header="安全实用工具" Foreground="#FFFFFF" Background="#2A2A2A">
                <Grid Margin="20">
                    <TextBlock Text="文件夹加密" FontSize="16" FontWeight="Bold" Foreground="#00BFFF" Margin="0,20,0,0"/>
                    <TextBox x:Name="FolderPathTextBox" Width="300" Height="30" Background="#2A2A2A" Foreground="#FFFFFF" BorderBrush="#2A2A2A" Margin="0,60,10,0"/>
                    <Button Content="浏览" Width="80" Height="30" Background="#2A2A2A" Foreground="#FFFFFF" Margin="310,60,0,0" Click="BrowseFolder_Click"/>
                    <PasswordBox x:Name="EncryptionPasswordBox" Width="300" Height="30" Background="#2A2A2A" Foreground="#FFFFFF" BorderBrush="#2A2A2A" Margin="0,100,10,0"/>
                    <TextBlock Text="加密密码" FontSize="12" Foreground="#888888" Margin="0,135,0,0"/>
                    <Button Content="加密文件夹" Width="150" Height="40" Background="#00BFFF" Foreground="#FFFFFF" Margin="0,160,0,0" Click="EncryptFolder_Click"/>
                    <Button Content="解密文件夹" Width="150" Height="40" Background="#2A2A2A" Foreground="#FFFFFF" Margin="160,160,0,0" Click="DecryptFolder_Click"/>
                    <TextBlock x:Name="EncryptionResultText" Text="" FontSize="14" Foreground="#888888" Margin="0,210,0,0"/>
                </Grid>
            </TabItem>
            
            <!-- 日常效率工具 -->
            <TabItem Header="日常效率工具" Foreground="#FFFFFF" Background="#2A2A2A">
                <Grid Margin="20">
                    <TextBlock Text="定时关机/重启/休眠" FontSize="16" FontWeight="Bold" Foreground="#00BFFF" Margin="0,20,0,0"/>
                    <ComboBox x:Name="TaskTypeComboBox" Width="150" Height="30" Background="#2A2A2A" Foreground="#FFFFFF" BorderBrush="#2A2A2A" Margin="0,60,10,0">
                        <ComboBoxItem>关机</ComboBoxItem>
                        <ComboBoxItem>重启</ComboBoxItem>
                        <ComboBoxItem>休眠</ComboBoxItem>
                    </ComboBox>
                    <TextBox x:Name="HoursTextBox" Width="50" Height="30" Background="#2A2A2A" Foreground="#FFFFFF" BorderBrush="#2A2A2A" Margin="160,60,10,0" Text="0"/>
                    <TextBlock Text="小时" FontSize="12" Foreground="#888888" Margin="220,65,0,0"/>
                    <TextBox x:Name="MinutesTextBox" Width="50" Height="30" Background="#2A2A2A" Foreground="#FFFFFF" BorderBrush="#2A2A2A" Margin="250,60,10,0" Text="30"/>
                    <TextBlock Text="分钟" FontSize="12" Foreground="#888888" Margin="310,65,0,0"/>
                    <Button Content="设置定时任务" Width="150" Height="40" Background="#00BFFF" Foreground="#FFFFFF" Margin="0,100,0,0" Click="SetTimer_Click"/>
                    <Button Content="取消定时任务" Width="150" Height="40" Background="#2A2A2A" Foreground="#FFFFFF" Margin="160,100,0,0" Click="CancelTimer_Click"/>
                    <TextBlock x:Name="TimerResultText" Text="" FontSize="14" Foreground="#888888" Margin="0,150,0,0"/>
                    
                    <TextBlock Text="随机密码生成器" FontSize="16" FontWeight="Bold" Foreground="#00BFFF" Margin="400,20,0,0"/>
                    <TextBox x:Name="PasswordLengthTextBox" Width="100" Height="30" Background="#2A2A2A" Foreground="#FFFFFF" BorderBrush="#2A2A2A" Margin="400,60,10,0" Text="12"/>
                    <TextBlock Text="密码长度" FontSize="12" Foreground="#888888" Margin="400,95,0,0"/>
                    <CheckBox x:Name="IncludeUppercaseCheckBox" Content="包含大写字母" Margin="400,120,0,0" Foreground="#FFFFFF" IsChecked="True"/>
                    <CheckBox x:Name="IncludeLowercaseCheckBox" Content="包含小写字母" Margin="400,145,0,0" Foreground="#FFFFFF" IsChecked="True"/>
                    <CheckBox x:Name="IncludeNumbersCheckBox" Content="包含数字" Margin="400,170,0,0" Foreground="#FFFFFF" IsChecked="True"/>
                    <CheckBox x:Name="IncludeSymbolsCheckBox" Content="包含特殊字符" Margin="400,195,0,0" Foreground="#FFFFFF" IsChecked="True"/>
                    <Button Content="生成密码" Width="150" Height="40" Background="#00BFFF" Foreground="#FFFFFF" Margin="400,230,0,0" Click="GeneratePassword_Click"/>
                    <TextBox x:Name="GeneratedPasswordTextBox" Width="300" Height="30" Background="#2A2A2A" Foreground="#FFFFFF" BorderBrush="#2A2A2A" Margin="400,280,0,0"/>
                    <Button Content="复制密码" Width="100" Height="30" Background="#2A2A2A" Foreground="#FFFFFF" Margin="710,280,0,0" Click="CopyPassword_Click"/>
                </Grid>
            </TabItem>
            
            <!-- Edge浏览器专项优化 -->
            <TabItem Header="Edge浏览器专项优化" Foreground="#FFFFFF" Background="#2A2A2A">
                <Grid Margin="20">
                    <TextBlock Text="Edge浏览器优化" FontSize="16" FontWeight="Bold" Foreground="#00BFFF" Margin="0,20,0,0"/>
                    <Button Content="一键优化Edge" Width="200" Height="50" Background="#00BFFF" Foreground="#FFFFFF" FontSize="14" FontWeight="Bold" Margin="0,60,0,10" Click="OptimizeEdge_Click"/>
                    <Button Content="还原默认设置" Width="200" Height="40" Background="#2A2A2A" Foreground="#FFFFFF" Margin="0,120,0,0" Click="RestoreEdgeDefaults_Click"/>
                    <TextBlock x:Name="EdgeOptimizationResultText" Text="" FontSize="14" Foreground="#888888" Margin="0,170,0,0"/>
                    
                    <TextBlock Text="优化内容" FontSize="14" FontWeight="Bold" Foreground="#FFFFFF" Margin="300,20,0,0"/>
                    <ListBox Margin="300,60,0,0" Width="400" Height="200" Background="#2A2A2A" Foreground="#FFFFFF" BorderBrush="#2A2A2A">
                        <ListBoxItem>关闭后台持续运行</ListBoxItem>
                        <ListBoxItem>关闭后台扩展加载</ListBoxItem>
                        <ListBoxItem>关闭启动加速常驻权限</ListBoxItem>
                        <ListBoxItem>关闭后台页面刷新</ListBoxItem>
                        <ListBoxItem>关闭睡眠后台占用</ListBoxItem>
                        <ListBoxItem>关闭云同步后台静默运行</ListBoxItem>
                        <ListBoxItem>清理残留缓存和日志</ListBoxItem>
                    </ListBox>
                </Grid>
            </TabItem>
            
            <!-- 磁盘深层优化 -->
            <TabItem Header="磁盘深层优化" Foreground="#FFFFFF" Background="#2A2A2A">
                <Grid Margin="20">
                    <TextBlock Text="NTFS冗余块深度释放" FontSize="16" FontWeight="Bold" Foreground="#00BFFF" Margin="0,20,0,0"/>
                    <Button Content="释放NTFS冗余块" Width="200" Height="40" Background="#00BFFF" Foreground="#FFFFFF" Margin="0,60,0,0" Click="ReleaseNtfsRedundancy_Click"/>
                    <TextBlock x:Name="NtfsReleaseResultText" Text="" FontSize="14" Foreground="#888888" Margin="0,110,0,0"/>
                    
                    <TextBlock Text="磁盘坏道快速检测" FontSize="16" FontWeight="Bold" Foreground="#00BFFF" Margin="300,20,0,0"/>
                    <ComboBox x:Name="DiskComboBox" Width="200" Height="30" Background="#2A2A2A" Foreground="#FFFFFF" BorderBrush="#2A2A2A" Margin="300,60,0,0"/>
                    <Button Content="开始检测" Width="150" Height="40" Background="#00BFFF" Foreground="#FFFFFF" Margin="300,100,0,0" Click="CheckDiskBadSectors_Click"/>
                    <TextBlock x:Name="DiskCheckResultText" Text="" FontSize="14" Foreground="#888888" Margin="300,150,0,0"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>