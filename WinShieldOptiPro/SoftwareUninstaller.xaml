<UserControl x:Class="WinShieldOptiPro.SoftwareUninstaller"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:WinShieldOptiPro"
             mc:Ignorable="d"
             d:DesignWidth="900" d:DesignHeight="700"
             Background="Transparent">
    <UserControl.Resources>
        <local:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style x:Key="TabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid>
                            <Border x:Name="Border" Background="{StaticResource TertiaryBackground}" BorderBrush="{StaticResource AccentColor}" BorderThickness="1,1,1,0" CornerRadius="5,5,0,0" Padding="15,10,15,10">
                                <ContentPresenter x:Name="ContentSite" ContentSource="Header" RecognizesAccessKey="True"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource AccentColor}"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#3A3A3A"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="{StaticResource TertiaryBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="{StaticResource AccentColor}" BorderThickness="1" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource AccentColor}"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#3A3A3A"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <!-- 标题栏 -->
        <Border Background="{StaticResource SecondaryBackground}" BorderThickness="0 0 0 1" BorderBrush="{StaticResource AccentColor}">
            <StackPanel Orientation="Horizontal" Margin="20,10,20,10">
                <TextBlock Text="软件卸载与残留清理" Style="{StaticResource SubtitleText}"/>
            </StackPanel>
        </Border>
        
        <!-- 主要内容区 -->
        <Grid Margin="20,60,20,60">
            <!-- 选项卡 -->
            <TabControl x:Name="UninstallTabs" Margin="0,0,0,60" TabStripPlacement="Top" Background="{StaticResource TertiaryBackground}">
                <TabItem Header="第三方软件" Style="{StaticResource TabItemStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,10,0,10">
                            <Button x:Name="RefreshThirdPartyButton" Content="刷新列表" Style="{StaticResource SecondaryButton}" Width="100" Height="30"/>
                            <Button x:Name="SelectAllThirdPartyButton" Content="全选" Style="{StaticResource SecondaryButton}" Width="80" Height="30"/>
                            <Button x:Name="UnselectAllThirdPartyButton" Content="取消全选" Style="{StaticResource SecondaryButton}" Width="100" Height="30"/>
                            <Button x:Name="UninstallThirdPartyButton" Content="卸载所选" Style="{StaticResource PrimaryButton}" Width="100" Height="30"/>
                            <Button x:Name="SilentUninstallThirdPartyButton" Content="静默卸载" Style="{StaticResource SecondaryButton}" Width="100" Height="30"/>
                        </StackPanel>
                        <ListBox x:Name="ThirdPartySoftwareList" Grid.Row="1" ItemContainerStyle="{StaticResource ListBoxItemStyle}" VirtualizingStackPanel.IsVirtualizing="True" ScrollViewer.CanContentScroll="True">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                                        <CheckBox x:Name="SoftwareCheckBox" IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="5,0,10,0" Foreground="{StaticResource TextPrimary}"/>
                                        <TextBlock Text="{Binding Name}" Style="{StaticResource BodyText}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Version}" Style="{StaticResource CaptionText}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        <TextBlock Text="{Binding Publisher}" Style="{StaticResource CaptionText}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </TabItem>
                <TabItem Header="Windows 自带软件" Style="{StaticResource TabItemStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,10,0,10">
                            <Button x:Name="RefreshUWPButton" Content="刷新列表" Style="{StaticResource SecondaryButton}" Width="100" Height="30"/>
                            <Button x:Name="SelectAllUWPButton" Content="全选" Style="{StaticResource SecondaryButton}" Width="80" Height="30"/>
                            <Button x:Name="UnselectAllUWPButton" Content="取消全选" Style="{StaticResource SecondaryButton}" Width="100" Height="30"/>
                            <Button x:Name="UninstallUWPButton" Content="卸载所选" Style="{StaticResource PrimaryButton}" Width="100" Height="30"/>
                            <Button x:Name="RestoreUWPButton" Content="恢复误卸" Style="{StaticResource SecondaryButton}" Width="100" Height="30"/>
                        </StackPanel>
                        <ListBox x:Name="UWPSoftwareList" Grid.Row="1" ItemContainerStyle="{StaticResource ListBoxItemStyle}" VirtualizingStackPanel.IsVirtualizing="True" ScrollViewer.CanContentScroll="True">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                                        <CheckBox x:Name="UWPSoftwareCheckBox" IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="5,0,10,0" Foreground="{StaticResource TextPrimary}"/>
                                        <TextBlock Text="{Binding Name}" Style="{StaticResource BodyText}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Publisher}" Style="{StaticResource CaptionText}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        <TextBlock x:Name="ProtectedIndicator" Text="[核心组件]" Style="{StaticResource CaptionText}" Foreground="{StaticResource WarningColor}" VerticalAlignment="Center" Margin="10,0,0,0" Visibility="{Binding IsProtected, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </TabItem>
                <TabItem Header="残留清理" Style="{StaticResource TabItemStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,10,0,10">
                            <Button x:Name="ScanResidualButton" Content="扫描残留" Style="{StaticResource PrimaryButton}" Width="100" Height="30"/>
                            <Button x:Name="CleanResidualButton" Content="清理所选残留" Style="{StaticResource SecondaryButton}" Width="120" Height="30"/>
                            <Button x:Name="CleanAllResidualButton" Content="清理全部残留" Style="{StaticResource SecondaryButton}" Width="120" Height="30"/>
                        </StackPanel>
                        <ListBox x:Name="ResidualList" Grid.Row="1" ItemContainerStyle="{StaticResource ListBoxItemStyle}" VirtualizingStackPanel.IsVirtualizing="True" ScrollViewer.CanContentScroll="True">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                                        <CheckBox x:Name="ResidualCheckBox" IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="5,0,10,0" Foreground="{StaticResource TextPrimary}"/>
                                        <TextBlock Text="{Binding Path}" Style="{StaticResource BodyText}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Size}" Style="{StaticResource CaptionText}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </TabItem>
            </TabControl>
            
            <!-- 底部状态栏 -->
            <Border Height="50" VerticalAlignment="Bottom" Background="{StaticResource SecondaryBackground}" BorderThickness="1 0 0 0" BorderBrush="{StaticResource AccentColor}">
                <Grid>
                    <TextBlock x:Name="StatusText" Text="就绪" Style="{StaticResource CaptionText}" Margin="20,15,0,0"/>
                    <ProgressBar x:Name="ProgressBar" Style="{StaticResource CustomProgressBar}" Width="300" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0" Visibility="Collapsed"/>
                </Grid>
            </Border>
        </Grid>
        
        <!-- 卸载动画 -->
        <Grid x:Name="UninstallAnimationGrid" Visibility="Collapsed" Background="Transparent">
            <Canvas x:Name="UninstallAnimationCanvas" Width="900" Height="700" HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- 动画元素将在这里动态添加 -->
            </Canvas>
        </Grid>
    </Grid>
</UserControl>