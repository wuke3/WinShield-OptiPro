<UserControl x:Class="WinShieldOptiPro.SoftwareUninstaller"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:WinShieldOptiPro"
             mc:Ignorable="d"
             d:DesignWidth="900" d:DesignHeight="700"
             Background="Transparent">
    <UserControl.Resources>
        <local:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style x:Key="TabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid>
                            <Border x:Name="Border" Background="#2A2A2A" BorderBrush="#3A3A3A" BorderThickness="1,1,1,0" CornerRadius="5,5,0,0" Padding="15,10,15,10">
                                <ContentPresenter x:Name="ContentSite" ContentSource="Header" RecognizesAccessKey="True"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#00BFFF"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#00BFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#3A3A3A"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#00BFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#00BFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,5,10,5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0099CC"/>
                                <Setter Property="BorderBrush" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0080AA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#00BFFF"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#00BFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#3A3A3A"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#00BFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <!-- 毛玻璃背景 -->
        <Border Background="#2A2A2A" CornerRadius="10" BorderBrush="#00BFFF" BorderThickness="1">
            <Border.Effect>
                <BlurEffect Radius="10"/>
            </Border.Effect>
        </Border>
        
        <!-- 标题栏 -->
        <Grid Height="40" VerticalAlignment="Top" Background="#1E1E1E">
            <TextBlock Text="软件卸载与残留清理" Foreground="#00BFFF" FontSize="14" FontWeight="Bold" Margin="20,10,0,0">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#00BFFF" BlurRadius="5" Opacity="0.8"/>
                </TextBlock.Effect>
            </TextBlock>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0">
                <Button x:Name="MinimizeButton" Width="30" Height="30" Background="Transparent" Foreground="White" BorderThickness="0" Content="_" FontSize="16"/>
                <Button x:Name="CloseButton" Width="30" Height="30" Background="Transparent" Foreground="White" BorderThickness="0" Content="X" FontSize="16"/>
            </StackPanel>
        </Grid>
        
        <!-- 主要内容区 -->
        <Grid Margin="20,60,20,60">
            <!-- 选项卡 -->
            <TabControl x:Name="UninstallTabs" Margin="0,0,0,60" TabStripPlacement="Top" Background="#2A2A2A">
                <TabItem Header="第三方软件" Style="{StaticResource TabItemStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,10,0,10">
                            <Button x:Name="RefreshThirdPartyButton" Content="刷新列表" Style="{StaticResource ButtonStyle}"/>
                            <Button x:Name="SelectAllThirdPartyButton" Content="全选" Style="{StaticResource ButtonStyle}"/>
                            <Button x:Name="UnselectAllThirdPartyButton" Content="取消全选" Style="{StaticResource ButtonStyle}"/>
                            <Button x:Name="UninstallThirdPartyButton" Content="卸载所选" Style="{StaticResource ButtonStyle}"/>
                            <Button x:Name="SilentUninstallThirdPartyButton" Content="静默卸载" Style="{StaticResource ButtonStyle}"/>
                        </StackPanel>
                        <ListBox x:Name="ThirdPartySoftwareList" Grid.Row="1" ItemContainerStyle="{StaticResource ListBoxItemStyle}" VirtualizingStackPanel.IsVirtualizing="True" ScrollViewer.CanContentScroll="True">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                                        <CheckBox x:Name="SoftwareCheckBox" IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="5,0,10,0"/>
                                        <TextBlock Text="{Binding Name}" Foreground="#CCCCCC" FontSize="14" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Version}" Foreground="#999999" FontSize="12" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        <TextBlock Text="{Binding Publisher}" Foreground="#999999" FontSize="12" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </TabItem>
                <TabItem Header="Windows 自带软件" Style="{StaticResource TabItemStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,10,0,10">
                            <Button x:Name="RefreshUWPButton" Content="刷新列表" Style="{StaticResource ButtonStyle}"/>
                            <Button x:Name="SelectAllUWPButton" Content="全选" Style="{StaticResource ButtonStyle}"/>
                            <Button x:Name="UnselectAllUWPButton" Content="取消全选" Style="{StaticResource ButtonStyle}"/>
                            <Button x:Name="UninstallUWPButton" Content="卸载所选" Style="{StaticResource ButtonStyle}"/>
                            <Button x:Name="RestoreUWPButton" Content="恢复误卸" Style="{StaticResource ButtonStyle}"/>
                        </StackPanel>
                        <ListBox x:Name="UWPSoftwareList" Grid.Row="1" ItemContainerStyle="{StaticResource ListBoxItemStyle}" VirtualizingStackPanel.IsVirtualizing="True" ScrollViewer.CanContentScroll="True">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                                        <CheckBox x:Name="UWPSoftwareCheckBox" IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="5,0,10,0"/>
                                        <TextBlock Text="{Binding Name}" Foreground="#CCCCCC" FontSize="14" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Publisher}" Foreground="#999999" FontSize="12" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        <TextBlock x:Name="ProtectedIndicator" Text="[核心组件]" Foreground="#FF9800" FontSize="12" VerticalAlignment="Center" Margin="10,0,0,0" Visibility="{Binding IsProtected, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </TabItem>
                <TabItem Header="残留清理" Style="{StaticResource TabItemStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,10,0,10">
                            <Button x:Name="ScanResidualButton" Content="扫描残留" Style="{StaticResource ButtonStyle}"/>
                            <Button x:Name="CleanResidualButton" Content="清理所选残留" Style="{StaticResource ButtonStyle}"/>
                            <Button x:Name="CleanAllResidualButton" Content="清理全部残留" Style="{StaticResource ButtonStyle}"/>
                        </StackPanel>
                        <ListBox x:Name="ResidualList" Grid.Row="1" ItemContainerStyle="{StaticResource ListBoxItemStyle}" VirtualizingStackPanel.IsVirtualizing="True" ScrollViewer.CanContentScroll="True">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                                        <CheckBox x:Name="ResidualCheckBox" IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="5,0,10,0"/>
                                        <TextBlock Text="{Binding Path}" Foreground="#CCCCCC" FontSize="14" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Size}" Foreground="#999999" FontSize="12" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </TabItem>
            </TabControl>
            
            <!-- 底部状态栏 -->
            <Grid Height="50" VerticalAlignment="Bottom" Background="#1E1E1E">
                <TextBlock x:Name="StatusText" Text="就绪" Foreground="#CCCCCC" FontSize="12" Margin="20,15,0,0"/>
                <ProgressBar x:Name="ProgressBar" Width="300" Height="10" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0" Visibility="Collapsed"/>
            </Grid>
        </Grid>
        
        <!-- 卸载动画 -->
        <Grid x:Name="UninstallAnimationGrid" Visibility="Collapsed" Background="Transparent">
            <Canvas x:Name="UninstallAnimationCanvas" Width="900" Height="700" HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- 动画元素将在这里动态添加 -->
            </Canvas>
        </Grid>
    </Grid>
</UserControl>