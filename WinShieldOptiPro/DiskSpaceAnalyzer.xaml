<UserControl x:Class="WinShieldOptiPro.DiskSpaceAnalyzer" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:WinShieldOptiPro" mc:Ignorable="d" d:DesignHeight="600" d:DesignWidth="1000">
    <Grid Background="{StaticResource PrimaryBackground}">
        <!-- 标题 -->
        <TextBlock Text="C盘空间分析" Style="{StaticResource TitleText}" Margin="20,20,0,0"/>
        
        <!-- 扫描按钮 -->
        <StackPanel Orientation="Horizontal" Margin="20,60,0,0" HorizontalAlignment="Left">
            <Button x:Name="ScanButton" Content="开始扫描" Style="{StaticResource PrimaryButton}" Click="ScanButton_Click"/>
            <Button x:Name="RefreshButton" Content="刷新" Style="{StaticResource SecondaryButton}" Width="100" Click="RefreshButton_Click"/>
            
            <!-- 扫描状态 -->
            <TextBlock x:Name="ScanStatusText" Text="准备就绪" Style="{StaticResource CaptionText}" Margin="20,10,0,0"/>
            <ProgressBar x:Name="ScanProgressBar" Style="{StaticResource CustomProgressBar}" Width="300" Margin="20,5,0,0" Visibility="Collapsed"/>
        </StackPanel>
        
        <!-- 文件类型筛选 -->
        <Grid Margin="20,120,20,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="文件类型筛选:" Style="{StaticResource BodyText}" Grid.Column="0"/>
            <StackPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Left">
                <ComboBox x:Name="FileTypeComboBox" Width="150" Height="30" Background="{StaticResource TertiaryBackground}" Foreground="{StaticResource TextPrimary}" BorderBrush="{StaticResource AccentColor}" Margin="0,0,10,0">
                    <ComboBoxItem Content="全部文件" IsSelected="True"/>
                    <ComboBoxItem Content="安装包"/>
                    <ComboBoxItem Content="视频"/>
                    <ComboBoxItem Content="压缩包"/>
                    <ComboBoxItem Content="图片"/>
                    <ComboBoxItem Content="文档"/>
                    <ComboBoxItem Content="其他"/>
                </ComboBox>
                <Button x:Name="FilterButton" Content="筛选" Style="{StaticResource PrimaryButton}" Width="100" Height="30" Click="FilterButton_Click"/>
            </StackPanel>
        </Grid>
        
        <!-- 双展示区域 -->
        <Grid Margin="20,170,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- 空间占用分布列表 -->
                <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,10,0">
                    <Grid>
                        <TextBlock Text="空间占用分布" Style="{StaticResource SubtitleText}" Margin="0,0,0,20"/>
                        <ListBox x:Name="DiskUsageListBox" Margin="0,40,0,0" Background="{StaticResource TertiaryBackground}" Foreground="{StaticResource TextPrimary}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                                        <TextBlock Text="{Binding Name}" Style="{StaticResource BodyText}" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding SizeText}" Style="{StaticResource CaptionText}" Foreground="{StaticResource AccentColor}" Margin="0,0,10,0"/>
                                        <ProgressBar Width="150" Height="10" Style="{StaticResource CustomProgressBar}" Value="{Binding Percentage}" Margin="0,5,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
                
                <!-- 树形目录展示 -->
                <Border Grid.Column="1" Style="{StaticResource CardBorder}" Margin="10,0,0,0">
                    <Grid>
                        <TextBlock Text="目录占用详情" Style="{StaticResource SubtitleText}" Margin="0,0,0,20"/>
                        <TreeView x:Name="DirectoryTreeView" Margin="0,40,0,0" Background="{StaticResource TertiaryBackground}" Foreground="{StaticResource TextPrimary}">
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate DataType="{x:Type local:DirectoryItem}" ItemsSource="{Binding SubItems}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" Style="{StaticResource BodyText}" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding SizeText}" Style="{StaticResource CaptionText}" Margin="0,0,10,0"/>
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </Grid>
                </Border>
            </Grid>
            
            <!-- 高危占用项标注 -->
            <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,20,0,0">
                <Grid>
                    <TextBlock Text="高危占用项" Style="{StaticResource SubtitleText}" Margin="0,0,0,20"/>
                    <ListBox x:Name="HighRiskItemsListBox" Margin="0,40,0,0" Background="{StaticResource TertiaryBackground}" Foreground="{StaticResource TextPrimary}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                                    <TextBlock Text="{Binding Name}" Style="{StaticResource BodyText}" Margin="0,0,10,0"/>
                                    <TextBlock Text="{Binding SizeText}" Style="{StaticResource CaptionText}" Foreground="{StaticResource WarningColor}" Margin="0,0,10,0"/>
                                    <TextBlock Text="{Binding Description}" Style="{StaticResource CaptionText}" Margin="0,0,10,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>