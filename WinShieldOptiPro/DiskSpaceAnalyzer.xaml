<UserControl x:Class="WinShieldOptiPro.DiskSpaceAnalyzer" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:WinShieldOptiPro" mc:Ignorable="d" d:DesignHeight="600" d:DesignWidth="1000">
    <Grid Background="#121212">
        <!-- 标题 -->
        <TextBlock Text="C盘空间分析" FontSize="20" FontWeight="Bold" Foreground="#00BFFF" Margin="20,20,0,0"/>
        
        <!-- 扫描按钮 -->
        <Button x:Name="ScanButton" Content="开始扫描" Width="120" Height="40" Background="#00BFFF" Foreground="#FFFFFF" Margin="20,60,0,0" Click="ScanButton_Click"/>
        <Button x:Name="RefreshButton" Content="刷新" Width="80" Height="40" Background="#2A2A2A" Foreground="#FFFFFF" Margin="150,60,0,0" Click="RefreshButton_Click"/>
        
        <!-- 扫描状态 -->
        <TextBlock x:Name="ScanStatusText" Text="准备就绪" FontSize="14" Foreground="#888888" Margin="240,70,0,0"/>
        <ProgressBar x:Name="ScanProgressBar" Height="10" Width="300" Background="#2A2A2A" BorderThickness="0" Margin="350,70,0,0" Visibility="Collapsed"/>
        
        <!-- 文件类型筛选 -->
        <Grid Margin="20,120,20,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="文件类型筛选:" FontSize="14" Foreground="#FFFFFF" Grid.Column="0"/>
            <StackPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Left">
                <ComboBox x:Name="FileTypeComboBox" Width="150" Height="30" Background="#2A2A2A" Foreground="#FFFFFF" BorderBrush="#3A3A3A" Margin="0,0,10,0">
                    <ComboBoxItem Content="全部文件" IsSelected="True"/>
                    <ComboBoxItem Content="安装包"/>
                    <ComboBoxItem Content="视频"/>
                    <ComboBoxItem Content="压缩包"/>
                    <ComboBoxItem Content="图片"/>
                    <ComboBoxItem Content="文档"/>
                    <ComboBoxItem Content="其他"/>
                </ComboBox>
                <Button x:Name="FilterButton" Content="筛选" Width="80" Height="30" Background="#00BFFF" Foreground="#FFFFFF" Click="FilterButton_Click"/>
            </StackPanel>
        </Grid>
        
        <!-- 双展示区域 -->
        <Grid Margin="20,170,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- 空间占用分布列表 -->
            <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="4" Margin="0,0,10,0">
                <Grid>
                    <TextBlock Text="空间占用分布" FontSize="14" FontWeight="Bold" Foreground="#FFFFFF" Margin="20,20,0,0"/>
                    <ListBox x:Name="DiskUsageListBox" Margin="20,60,20,20" Background="#121212" Foreground="#FFFFFF">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" Margin="0,0,10,0"/>
                                    <TextBlock Text="{Binding SizeText}" Foreground="#00BFFF" FontSize="12" Margin="0,0,10,0"/>
                                    <ProgressBar Width="150" Height="10" Background="#2A2A2A" BorderThickness="0" Value="{Binding Percentage}" Margin="0,5,0,0">
                                        <ProgressBar.Foreground>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#00BFFF" Offset="0"/>
                                                <GradientStop Color="#007FFF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </ProgressBar.Foreground>
                                    </ProgressBar>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
            
            <!-- 树形目录展示 -->
            <Border Grid.Column="1" Background="#1E1E1E" CornerRadius="4" Margin="10,0,0,0">
                <Grid>
                    <TextBlock Text="目录占用详情" FontSize="14" FontWeight="Bold" Foreground="#FFFFFF" Margin="20,20,0,0"/>
                    <TreeView x:Name="DirectoryTreeView" Margin="20,60,20,20" Background="#121212" Foreground="#FFFFFF">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate DataType="{x:Type local:DirectoryItem}" ItemsSource="{Binding SubItems}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" Margin="0,0,10,0"/>
                                    <TextBlock Text="{Binding SizeText}" Foreground="#888888" FontSize="12"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>
            </Border>
        </Grid>
        
        <!-- 高危占用项标注 -->
        <Border Margin="20,570,20,20" Background="#1E1E1E" CornerRadius="4">
            <Grid>
                <TextBlock Text="高危占用项" FontSize="14" FontWeight="Bold" Foreground="#FFFFFF" Margin="20,20,0,0"/>
                <ListBox x:Name="HighRiskItemsListBox" Margin="20,60,20,20" Background="#121212" Foreground="#FFFFFF">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" Margin="0,0,10,0"/>
                                <TextBlock Text="{Binding SizeText}" Foreground="#FF4500" FontSize="12" Margin="0,0,10,0"/>
                                <TextBlock Text="{Binding Description}" Foreground="#888888" FontSize="12"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>