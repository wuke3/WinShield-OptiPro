<UserControl x:Class="WinShieldOptiPro.AppDataMonitor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900">
    <Grid Background="#121212">
        <!-- 标题 -->
        <TextBlock Text="AppData实时监控" FontSize="24" FontWeight="Bold" Foreground="#00BFFF" Margin="20,20,0,0"/>
        
        <!-- 监控控制 -->
        <Border Margin="20,60,20,0" Background="#1E1E1E" CornerRadius="8">
            <Grid Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="监控状态" FontSize="14" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,10"/>
                    <TextBlock x:Name="MonitorStatusText" Text="未启动" FontSize="16" Foreground="#FF4500"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1">
                    <TextBlock Text="监控路径" FontSize="14" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,10"/>
                    <TextBlock x:Name="MonitorPathText" Text="AppData全目录" FontSize="12" Foreground="#888888" TextWrapping="Wrap"/>
                </StackPanel>
                
                <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                    <Button x:Name="StartMonitorButton" Content="启动监控" Width="120" Height="40" Background="#00BFFF" Foreground="#FFFFFF" FontSize="14" FontWeight="Bold" Click="StartMonitorButton_Click"/>
                    <Button x:Name="StopMonitorButton" Content="停止监控" Width="120" Height="40" Background="#2A2A2A" Foreground="#FFFFFF" FontSize="14" FontWeight="Bold" Margin="0,10,0,0" Click="StopMonitorButton_Click" IsEnabled="False"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- 监控设置 -->
        <Border Margin="20,180,20,0" Background="#1E1E1E" CornerRadius="8">
            <Grid Margin="20">
                <TextBlock Text="监控设置" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,20"/>
                
                <StackPanel Margin="0,40,0,0">
                    <CheckBox x:Name="AutoStartCheckBox" Content="开机自启" Foreground="#FFFFFF"/>
                    <CheckBox x:Name="BackgroundMonitorCheckBox" Content="后台常驻监控" Foreground="#FFFFFF" Margin="0,10,0,0"/>
                    <CheckBox x:Name="AlertCheckBox" Content="异常写入提醒" Foreground="#FFFFFF" Margin="0,10,0,0"/>
                </StackPanel>
                
                <StackPanel Margin="300,40,0,0" HorizontalAlignment="Left">
                    <TextBlock Text="异常写入阈值" FontSize="14" Foreground="#888888" Margin="0,0,0,10"/>
                    <Grid>
                        <Slider x:Name="AlertThresholdSlider" Minimum="10" Maximum="1000" Value="100" Width="200"/>
                        <TextBlock x:Name="AlertThresholdText" Text="100 MB/分钟" FontSize="12" Foreground="#888888" Margin="210,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- 监控日志 -->
        <Border Margin="20,320,20,0" Background="#1E1E1E" CornerRadius="8">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="监控日志" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="ExportLogButton" Content="导出日志" Width="100" Height="30" Background="#2A2A2A" Foreground="#FFFFFF" BorderThickness="0" Margin="0,0,10,0" Click="ExportLogButton_Click"/>
                        <Button x:Name="ClearLogButton" Content="清空日志" Width="100" Height="30" Background="#2A2A2A" Foreground="#FFFFFF" BorderThickness="0" Click="ClearLogButton_Click"/>
                    </StackPanel>
                </Grid>
                
                <DataGrid x:Name="MonitorLogDataGrid" Grid.Row="1" AutoGenerateColumns="False" Background="#121212" Foreground="#FFFFFF" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="时间" Binding="{Binding Time}" Width="150"/>
                        <DataGridTextColumn Header="进程" Binding="{Binding ProcessName}" Width="150"/>
                        <DataGridTextColumn Header="操作" Binding="{Binding Operation}" Width="100"/>
                        <DataGridTextColumn Header="文件路径" Binding="{Binding FilePath}" Width="*"/>
                        <DataGridTextColumn Header="大小" Binding="{Binding Size}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
        
        <!-- 软件分类统计 -->
        <Border Margin="20,520,20,40" Background="#1E1E1E" CornerRadius="8">
            <Grid Margin="20">
                <TextBlock Text="软件分类统计" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,20"/>
                <DataGrid x:Name="SoftwareStatsDataGrid" AutoGenerateColumns="False" Background="#121212" Foreground="#FFFFFF" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="软件名称" Binding="{Binding SoftwareName}" Width="150"/>
                        <DataGridTextColumn Header="写入次数" Binding="{Binding WriteCount}" Width="100"/>
                        <DataGridTextColumn Header="占用空间" Binding="{Binding SpaceUsed}" Width="120"/>
                        <DataGridTextColumn Header="最近写入" Binding="{Binding LastWriteTime}" Width="150"/>
                        <DataGridTemplateColumn Header="操作" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="添加白名单" Width="80" Height="25" Background="#2A2A2A" Foreground="#FFFFFF" BorderThickness="0" Click="AddWhitelistButton_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>