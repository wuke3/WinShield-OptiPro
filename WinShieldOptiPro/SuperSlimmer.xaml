<UserControl x:Class="WinShieldOptiPro.SuperSlimmer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WinShieldOptiPro"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000">
    <Grid Background="#121212">
        <!-- 标题 -->
        <TextBlock Text="独家超级瘦身" FontSize="24" FontWeight="Bold" Foreground="#00BFFF" Margin="20,20,0,0"/>
        
        <!-- 清理选项 -->
        <Border Margin="20,60,20,0" Background="#1E1E1E" CornerRadius="8">
            <Grid Margin="20">
                <TextBlock Text="瘦身选项" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,20"/>
                
                <!-- 跨软件重复缓存瘦身 -->
                <Expander Header="跨软件重复缓存瘦身" FontSize="14" FontWeight="Bold" Foreground="#00BFFF" Margin="0,40,0,0" IsExpanded="True">
                    <StackPanel Margin="20,10,0,10">
                        <CheckBox x:Name="DuplicateCacheCheckBox" Content="识别AppData内多软件共用重复缓存，替换为硬链接" Margin="0,5,0,0" Foreground="#FFFFFF"/>
                        <TextBlock Text="预计释放空间：5-30GB" FontSize="12" Foreground="#888888" Margin="20,5,0,0"/>
                    </StackPanel>
                </Expander>
                
                <!-- 软件增量快照清理 -->
                <Expander Header="软件增量快照清理" FontSize="14" FontWeight="Bold" Foreground="#00BFFF" Margin="0,120,0,0" IsExpanded="True">
                    <StackPanel Margin="20,10,0,10">
                        <CheckBox x:Name="IncrementalSnapshotsCheckBox" Content="清理微信、Adobe、办公软件过期历史备份、增量缓存" Margin="0,5,0,0" Foreground="#FFFFFF"/>
                        <TextBlock Text="预计释放空间：10-40GB" FontSize="12" Foreground="#888888" Margin="20,5,0,0"/>
                    </StackPanel>
                </Expander>
                
                <!-- 孤儿链接残留清理 -->
                <Expander Header="孤儿链接残留清理" FontSize="14" FontWeight="Bold" Foreground="#00BFFF" Margin="0,200,0,0" IsExpanded="True">
                    <StackPanel Margin="20,10,0,10">
                        <CheckBox x:Name="OrphanLinksCheckBox" Content="扫描清理无效目录联接、软件卸载后孤儿文件" Margin="0,5,0,0" Foreground="#FFFFFF"/>
                        <TextBlock Text="预计释放空间：3-15GB" FontSize="12" Foreground="#888888" Margin="20,5,0,0"/>
                    </StackPanel>
                </Expander>
            </Grid>
        </Border>
        
        <!-- 操作按钮 -->
        <Grid Margin="20,300,20,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="ScanButton" Content="扫描分析" Width="150" Height="50" Background="#00BFFF" Foreground="#FFFFFF" FontSize="14" FontWeight="Bold" Grid.Column="0" Margin="0,0,10,0" Click="ScanButton_Click"/>
            <Button x:Name="SingleCleanButton" Content="单项清理" Width="150" Height="50" Background="#2A2A2A" Foreground="#FFFFFF" FontSize="14" FontWeight="Bold" Grid.Column="1" Margin="10,0,10,0" Click="SingleCleanButton_Click"/>
            <Button x:Name="FullCleanButton" Content="一键全套瘦身" Width="180" Height="50" Background="#00BFFF" Foreground="#FFFFFF" FontSize="14" FontWeight="Bold" Grid.Column="2" Margin="10,0,0,0" Click="FullCleanButton_Click"/>
        </Grid>
        
        <!-- 扫描结果 -->
        <Border Margin="20,370,20,40" Background="#1E1E1E" CornerRadius="8">
            <Grid Margin="20">
                <TextBlock Text="扫描结果" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,20"/>
                <TextBlock x:Name="ScanResultText" Text="请点击扫描按钮开始分析" FontSize="14" Foreground="#888888"/>
                <TextBlock x:Name="CleanResultText" Text="" FontSize="14" Foreground="#00FF00" Margin="0,40,0,0"/>
                <ProgressBar x:Name="ScanProgressBar" Height="10" Margin="0,80,0,0" Background="#2A2A2A" BorderThickness="0" Visibility="Collapsed"/>
                <TextBlock x:Name="ProgressText" Text="" FontSize="12" Foreground="#888888" Margin="0,100,0,0" Visibility="Collapsed"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>