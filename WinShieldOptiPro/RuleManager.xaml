<Window x:Class="WinShieldOptiPro.RuleManager"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="规则管理"
        Width="600"
        Height="400"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">
    <Window.Resources>
        <Style TargetType="Button" x:Key="PrimaryButton">
            <Setter Property="Background" Value="#0078D7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="#0078D7"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                                <Setter Property="BorderBrush" Value="#00A4EF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#004785"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ListBox" x:Key="CustomListBox">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="#252525"/>
                        <Setter Property="Foreground" Value="#E0E0E0"/>
                        <Setter Property="Padding" Value="10,5"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#333333"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#0078D7"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <!-- 背景渐变 -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0A0A0A" Offset="0"/>
                <GradientStop Color="#1A1A1A" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        
        <!-- 毛玻璃效果 -->
        <Border BorderThickness="1" BorderBrush="#333333" CornerRadius="8" Margin="2">
            <Border.Background>
                <SolidColorBrush Color="#1E1E1E" Opacity="0.8"/>
            </Border.Background>
        </Border>
        
        <!-- 主内容 -->
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>
            
            <!-- 顶部标题栏 -->
            <Border Grid.Row="0" Background="#252525" BorderBrush="#0078D7" BorderThickness="0 0 0 1" CornerRadius="4 4 0 0">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="20,0,0,0">
                        <TextBlock Text="规则管理" FontSize="16" FontWeight="Bold" Foreground="#00A4EF">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#00A4EF" BlurRadius="10" Opacity="0.5"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
                        <Button Content="关闭" Width="60" Height="25" Margin="5" Click="CloseWindow" Background="#2A2A2A" Foreground="#E0E0E0" BorderBrush="#333333"/>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- 主要内容区 -->
            <Grid Grid.Row="1" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- 黑名单 -->
                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="黑名单" FontSize="14" FontWeight="Bold" Foreground="#E0E0E0"/>
                        <TextBlock x:Name="BlacklistCount" Text="(0)" FontSize="14" Foreground="#00A4EF" Margin="10,0,0,0">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#00A4EF" BlurRadius="5" Opacity="0.5"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </StackPanel>
                    <Border BorderThickness="1" BorderBrush="#333333" CornerRadius="4" Background="#1A1A1A">
                        <ListBox x:Name="BlacklistBox" Style="{StaticResource CustomListBox}" Height="200"/>
                    </Border>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                        <Button Content="添加" Style="{StaticResource PrimaryButton}" Click="AddToBlacklist"/>
                        <Button Content="删除" Style="{StaticResource PrimaryButton}" Click="RemoveFromBlacklist"/>
                    </StackPanel>
                </StackPanel>
                
                <!-- 白名单 -->
                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="白名单" FontSize="14" FontWeight="Bold" Foreground="#E0E0E0"/>
                        <TextBlock x:Name="WhitelistCount" Text="(0)" FontSize="14" Foreground="#00A4EF" Margin="10,0,0,0">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#00A4EF" BlurRadius="5" Opacity="0.5"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </StackPanel>
                    <Border BorderThickness="1" BorderBrush="#333333" CornerRadius="4" Background="#1A1A1A">
                        <ListBox x:Name="WhitelistBox" Style="{StaticResource CustomListBox}" Height="200"/>
                    </Border>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                        <Button Content="添加" Style="{StaticResource PrimaryButton}" Click="AddToWhitelist"/>
                        <Button Content="删除" Style="{StaticResource PrimaryButton}" Click="RemoveFromWhitelist"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
            
            <!-- 底部按钮 -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button Content="保存" Style="{StaticResource PrimaryButton}" Click="SaveRules"/>
                <Button Content="取消" Style="{StaticResource PrimaryButton}" Click="CloseWindow"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>