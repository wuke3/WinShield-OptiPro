<UserControl x:Class="WinShieldOptiPro.SettingsAndSecurity"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WinShieldOptiPro"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900">
    <Grid Background="#121212">
        <!-- 标题 -->
        <TextBlock Text="基础设置 &amp; 安全中心" FontSize="24" FontWeight="Bold" Foreground="#00BFFF" Margin="20,20,0,0"/>
        
        <!-- 管理员权限校验 -->
        <Border Margin="20,60,20,0" Background="#1E1E1E" CornerRadius="8">
            <Grid Margin="20">
                <TextBlock Text="管理员权限校验" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,20"/>
                <StackPanel>
                    <TextBlock x:Name="AdminStatusText" Text="当前状态: 已获取管理员权限" FontSize="14" Foreground="#00FF00"/>
                    <TextBlock Text="软件启动时会自动校验管理员权限，确保清理、优化功能正常运行" FontSize="12" Foreground="#888888" Margin="0,5,0,0"/>
                    <Button x:Name="CheckAdminButton" Content="重新校验权限" Width="150" Height="40" Background="#00BFFF" Foreground="#FFFFFF" Margin="0,10,0,0" Click="CheckAdminButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- C盘空间阈值提醒 -->
        <Border Margin="20,180,20,0" Background="#1E1E1E" CornerRadius="8">
            <Grid Margin="20">
                <TextBlock Text="C盘空间阈值提醒" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,20"/>
                <StackPanel>
                    <TextBlock Text="当C盘剩余空间低于阈值时，将自动弹出提醒" FontSize="14" Foreground="#888888"/>
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="阈值设置:" FontSize="14" Foreground="#FFFFFF" Grid.Column="0" VerticalAlignment="Center"/>
                        <Grid Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="DiskThresholdSlider" Minimum="1" Maximum="20" Value="5" TickFrequency="1" IsSnapToTickEnabled="True" Background="#2A2A2A" Foreground="#00BFFF" Grid.Column="0"/>
                            <TextBlock x:Name="DiskThresholdText" Text="5 GB" FontSize="14" Foreground="#00BFFF" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Grid>
                    <CheckBox x:Name="EnableDiskThresholdCheckBox" Content="启用C盘空间阈值提醒" FontSize="14" Foreground="#FFFFFF" Margin="0,10,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- 清理备份设置 -->
        <Border Margin="20,300,20,0" Background="#1E1E1E" CornerRadius="8">
            <Grid Margin="20">
                <TextBlock Text="清理备份设置" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,20"/>
                <StackPanel>
                    <CheckBox x:Name="EnableBackupCheckBox" Content="清理前创建备份" FontSize="14" Foreground="#FFFFFF"/>
                    <TextBlock Text="备份文件将保存7天，过期自动清理" FontSize="12" Foreground="#888888" Margin="0,5,0,0"/>
                    <CheckBox x:Name="EnableAutoCleanCheckBox" Content="启用自动清理" FontSize="14" Foreground="#FFFFFF" Margin="0,10,0,0" IsChecked="False"/>
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="自动清理周期:" FontSize="14" Foreground="#FFFFFF" Grid.Column="0" VerticalAlignment="Center"/>
                        <ComboBox x:Name="AutoCleanPeriodComboBox" Grid.Column="1" Background="#2A2A2A" Foreground="#FFFFFF" BorderBrush="#2A2A2A">
                            <ComboBoxItem Content="每天"/>
                            <ComboBoxItem Content="每周" IsSelected="True"/>
                            <ComboBoxItem Content="每月"/>
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- 白名单设置 -->
        <Border Margin="20,420,20,0" Background="#1E1E1E" CornerRadius="8">
            <Grid Margin="20">
                <TextBlock Text="白名单设置" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,20"/>
                <StackPanel>
                    <TextBlock Text="锁定不清理目录" FontSize="14" FontWeight="Bold" Foreground="#00BFFF"/>
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="ProtectedDirectoryTextBox" Grid.Column="0" Background="#2A2A2A" Foreground="#FFFFFF" BorderBrush="#2A2A2A"/>
                        <Button x:Name="AddProtectedDirButton" Content="添加" Width="80" Height="30" Background="#00BFFF" Foreground="#FFFFFF" Grid.Column="1" Margin="10,0,0,0" Click="AddProtectedDirButton_Click"/>
                    </Grid>
                    <ListBox x:Name="ProtectedDirectoriesListBox" Background="#2A2A2A" Foreground="#FFFFFF" Margin="0,10,0,0" Height="80"/>
                    
                    <TextBlock Text="信任软件" FontSize="14" FontWeight="Bold" Foreground="#00BFFF" Margin="0,20,0,0"/>
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TrustedSoftwareTextBox" Grid.Column="0" Background="#2A2A2A" Foreground="#FFFFFF" BorderBrush="#2A2A2A"/>
                        <Button x:Name="AddTrustedSoftwareButton" Content="添加" Width="80" Height="30" Background="#00BFFF" Foreground="#FFFFFF" Grid.Column="1" Margin="10,0,0,0" Click="AddTrustedSoftwareButton_Click"/>
                    </Grid>
                    <ListBox x:Name="TrustedSoftwareListBox" Background="#2A2A2A" Foreground="#FFFFFF" Margin="0,10,0,0" Height="80"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- 系统还原点管理 -->
        <Border Margin="20,620,20,40" Background="#1E1E1E" CornerRadius="8">
            <Grid Margin="20">
                <TextBlock Text="系统还原点管理" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,20"/>
                <StackPanel>
                    <Button x:Name="CreateRestorePointButton" Content="创建还原点" Width="150" Height="40" Background="#00BFFF" Foreground="#FFFFFF" Click="CreateRestorePointButton_Click"/>
                    <ListBox x:Name="RestorePointsListBox" Background="#2A2A2A" Foreground="#FFFFFF" Margin="0,10,0,0" Height="100"/>
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="RefreshRestorePointsButton" Content="刷新列表" Width="120" Height="30" Background="#2A2A2A" Foreground="#FFFFFF" Grid.Column="1" Margin="0,0,10,0" Click="RefreshRestorePointsButton_Click"/>
                        <Button x:Name="DeleteRestorePointButton" Content="删除选中" Width="120" Height="30" Background="#FF4500" Foreground="#FFFFFF" Grid.Column="2" Click="DeleteRestorePointButton_Click"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>