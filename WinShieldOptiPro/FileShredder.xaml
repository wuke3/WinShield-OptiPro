<UserControl x:Class="WinShieldOptiPro.FileShredder"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="#2A2A2A">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Grid Grid.Row="0" Background="#1E1E1E">
            <TextBlock Text="文件粉碎" FontSize="24" Foreground="#00BFFF" Margin="20,0,0,0" VerticalAlignment="Center">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#00BFFF" BlurRadius="10" Opacity="0.8"/>
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock Text="彻底删除文件，数据不可恢复" FontSize="14" Foreground="#888888" Margin="20,30,0,0"/>
        </Grid>

        <!-- 内容区 -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 操作按钮 -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                <Button x:Name="AddFilesButton" Content="添加文件" Width="100" Height="36" Background="#3A3A3A" Foreground="White" BorderBrush="#00BFFF" BorderThickness="1" Margin="0,0,10,0">
                    <Button.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </TransformGroup>
                    </Button.RenderTransform>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4" BorderThickness="1" BorderBrush="{TemplateBinding BorderBrush}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="RenderTransform">
                                                    <Setter.Value>
                                                        <TransformGroup>
                                                            <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                                        </TransformGroup>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="BorderBrush" Value="#FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="AddFolderButton" Content="添加文件夹" Width="120" Height="36" Background="#3A3A3A" Foreground="White" BorderBrush="#00BFFF" BorderThickness="1" Margin="0,0,10,0">
                    <Button.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </TransformGroup>
                    </Button.RenderTransform>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4" BorderThickness="1" BorderBrush="{TemplateBinding BorderBrush}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="RenderTransform">
                                                    <Setter.Value>
                                                        <TransformGroup>
                                                            <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                                        </TransformGroup>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="BorderBrush" Value="#FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="ClearListButton" Content="清空列表" Width="100" Height="36" Background="#3A3A3A" Foreground="White" BorderBrush="#00BFFF" BorderThickness="1">
                    <Button.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </TransformGroup>
                    </Button.RenderTransform>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4" BorderThickness="1" BorderBrush="{TemplateBinding BorderBrush}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="RenderTransform">
                                                    <Setter.Value>
                                                        <TransformGroup>
                                                            <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                                        </TransformGroup>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="BorderBrush" Value="#FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <!-- 文件列表 -->
            <DataGrid x:Name="FilesDataGrid" Grid.Row="1" Background="#2A2A2A" Foreground="White" BorderBrush="#3A3A3A" BorderThickness="1">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="文件路径" Width="*" Binding="{Binding Path}"/>
                    <DataGridTextColumn Header="类型" Width="100" Binding="{Binding Type}"/>
                    <DataGridTextColumn Header="大小" Width="120" Binding="{Binding Size}"/>
                </DataGrid.Columns>
                <DataGrid.Effect>
                    <DropShadowEffect Color="#00BFFF" BlurRadius="5" Opacity="0.3"/>
                </DataGrid.Effect>
            </DataGrid>

            <!-- 右键菜单状态 -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,20,0,0" VerticalAlignment="Center">
                <TextBlock Text="右键菜单状态: " Foreground="#888888" Margin="0,0,10,0"/>
                <TextBlock x:Name="ContextMenuStatusText" Foreground="#00BFFF"/>
                <Button x:Name="ToggleContextMenuButton" Width="120" Height="36" Background="#3A3A3A" Foreground="White" BorderBrush="#00BFFF" BorderThickness="1" Margin="20,0,0,0">
                    <Button.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </TransformGroup>
                    </Button.RenderTransform>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4" BorderThickness="1" BorderBrush="{TemplateBinding BorderBrush}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="RenderTransform">
                                                    <Setter.Value>
                                                        <TransformGroup>
                                                            <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                                        </TransformGroup>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="BorderBrush" Value="#FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>

        <!-- 底部操作栏 -->
        <Grid Grid.Row="2" Background="#1E1E1E" Margin="0,20,0,0">
            <Button x:Name="ShredButton" Content="开始粉碎" Width="150" Height="40" Background="#00BFFF" Foreground="White" BorderThickness="0" Margin="20,0,0,0" HorizontalAlignment="Left">
                <Button.Effect>
                    <DropShadowEffect Color="#00BFFF" BlurRadius="10" Opacity="0.8"/>
                </Button.Effect>
                <Button.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </TransformGroup>
                </Button.RenderTransform>
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8" BorderThickness="2" BorderBrush="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <TransformGroup>
                                                        <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                                    </TransformGroup>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="BorderBrush" Value="#FFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
            <TextBlock x:Name="StatusText" Foreground="#888888" Margin="200,0,0,0" VerticalAlignment="Center"/>
        </Grid>
        
        <!-- 文件粉碎动画 -->
        <Grid x:Name="ShredAnimationGrid" Grid.Row="1" Visibility="Collapsed" Background="Transparent">
            <Canvas x:Name="ShredAnimationCanvas" Width="800" Height="400" HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- 动画元素将在这里动态添加 -->
            </Canvas>
        </Grid>
    </Grid>
</UserControl>