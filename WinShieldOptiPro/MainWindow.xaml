﻿<Window x:Class="WinShieldOptiPro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WinShieldOptiPro"
        mc:Ignorable="d"
        Title="WinShield OptiPro" MinHeight="600" MinWidth="1024" Height="768" Width="1366" WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        MouseDown="Window_MouseDown"
        MouseMove="Window_MouseMove"
        MouseUp="Window_MouseUp">
    <Grid>
        <!-- 渐变背景 -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0A0A0A" Offset="0"/>
                <GradientStop Color="#1A1A2E" Offset="0.5"/>
                <GradientStop Color="#16213E" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        
        <!-- 主网格 -->
        <Border Background="{StaticResource PrimaryBackground}" Margin="10" CornerRadius="12">
            <Border.Effect>
                <DropShadowEffect Color="{StaticResource AccentColor}" BlurRadius="20" Opacity="0.3"/>
            </Border.Effect>
            <Grid>
                <!-- 顶部控制栏 -->
                <Border Height="60" Background="{StaticResource SecondaryBackground}">
                    <Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="20,0,0,0">
                            <TextBlock Text="WinShield OptiPro" Style="{StaticResource SubtitleText}"/>
                            <TextBlock Text=" - 空闲" Style="{StaticResource CaptionText}" Margin="10,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
                            <Button Content="🌙" Width="30" Height="30" Background="Transparent" Foreground="{StaticResource TextPrimary}" BorderThickness="0" Margin="0,0,10,0" AutomationProperties.Name="主题切换" AutomationProperties.Description="切换应用程序主题" TabIndex="1"/>
                            <Button Content="📱" Width="30" Height="30" Background="Transparent" Foreground="{StaticResource TextPrimary}" BorderThickness="0" Margin="0,0,10,0" AutomationProperties.Name="设备管理" AutomationProperties.Description="管理设备设置" TabIndex="2"/>
                            <Button Content="-" Width="30" Height="30" Background="Transparent" Foreground="{StaticResource TextPrimary}" BorderThickness="0" Margin="0,0,10,0" Click="MinimizeButton_Click" AutomationProperties.Name="最小化" AutomationProperties.Description="最小化应用程序窗口" TabIndex="3"/>
                            <Button Content="✕" Width="30" Height="30" Background="Transparent" Foreground="{StaticResource TextPrimary}" BorderThickness="0" Click="CloseButton_Click" AutomationProperties.Name="关闭" AutomationProperties.Description="关闭应用程序" TabIndex="4"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 主内容网格 -->
                <Grid Margin="0,60,0,40">
                    <!-- 左侧导航栏 -->
                    <Grid Width="200" Background="{StaticResource TertiaryBackground}" HorizontalAlignment="Left">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Orientation="Vertical" Margin="0,20,0,20">
                                <Button x:Name="HomeButton" Content="首页" Click="HomeButton_Click" Style="{StaticResource PrimaryButton}" Width="180" Height="50" Margin="10,0,10,10" AutomationProperties.Name="首页" AutomationProperties.Description="返回首页概览" TabIndex="5">
                                <Button.Effect>
                                    <DropShadowEffect Color="{StaticResource AccentColor}" BlurRadius="10" Opacity="0.8"/>
                                </Button.Effect>
                            </Button>
                            <Button x:Name="HardwareOverviewButton" Content="硬件概览" Click="HardwareOverviewButton_Click" Style="{StaticResource NavButton}" AutomationProperties.Name="硬件概览" AutomationProperties.Description="查看硬件信息" TabIndex="6"/>
                            <Button x:Name="DiskSpaceAnalyzerButton" Content="空间分析" Click="DiskSpaceAnalyzerButton_Click" Style="{StaticResource NavButton}" AutomationProperties.Name="空间分析" AutomationProperties.Description="分析磁盘空间使用情况" TabIndex="7"/>
                            <Button x:Name="JunkCleanButton" Content="垃圾清理" Click="JunkCleanButton_Click" Style="{StaticResource NavButton}" AutomationProperties.Name="垃圾清理" AutomationProperties.Description="清理系统垃圾文件" TabIndex="8"/>
                            <Button x:Name="SystemOptimizeButtonNav" Content="系统优化" Click="SystemOptimizeButtonNav_Click" Style="{StaticResource NavButton}" AutomationProperties.Name="系统优化" AutomationProperties.Description="优化系统性能" TabIndex="9"/>
                            <Button x:Name="MemoryOptimizerButton" Content="内存优化" Click="MemoryOptimizerButton_Click" Style="{StaticResource NavButton}" AutomationProperties.Name="内存优化" AutomationProperties.Description="优化内存使用" TabIndex="10"/>
                            <Button x:Name="AppDataMonitorButton" Content="AppData监控" Click="AppDataMonitorButton_Click" Style="{StaticResource NavButton}" AutomationProperties.Name="AppData监控" AutomationProperties.Description="监控应用数据使用" TabIndex="11"/>
                            <Button x:Name="SoftwareUninstallerButton" Content="软件卸载" Click="SoftwareUninstallerButton_Click" Style="{StaticResource NavButton}" AutomationProperties.Name="软件卸载" AutomationProperties.Description="卸载不需要的软件" TabIndex="12"/>
                            <Button x:Name="SuperSlimmerButton" Content="超级瘦身" Click="SuperSlimmerButton_Click" Style="{StaticResource NavButton}" AutomationProperties.Name="超级瘦身" AutomationProperties.Description="深度清理系统" TabIndex="13"/>
                            <Button x:Name="SystemToolboxButton" Content="系统工具箱" Click="SystemToolboxButton_Click" Style="{StaticResource NavButton}" AutomationProperties.Name="系统工具箱" AutomationProperties.Description="访问系统工具" TabIndex="14"/>
                            <Button x:Name="PopupBlockerButton" Content="弹窗拦截" Click="PopupBlockerButton_Click" Style="{StaticResource NavButton}" AutomationProperties.Name="弹窗拦截" AutomationProperties.Description="拦截弹窗广告" TabIndex="15"/>
                            <Button x:Name="FreezeRestoreButton" Content="冰点还原" Click="FreezeRestoreButton_Click" Style="{StaticResource NavButton}" AutomationProperties.Name="冰点还原" AutomationProperties.Description="系统还原功能" TabIndex="16"/>
                            <Button x:Name="SystemScannerButton" Content="静默查杀" Click="SystemScannerButton_Click" Style="{StaticResource NavButton}" AutomationProperties.Name="静默查杀" AutomationProperties.Description="扫描系统安全" TabIndex="17"/>
                            <Button x:Name="FileShredderButton" Content="文件粉碎" Click="FileShredderButton_Click" Style="{StaticResource NavButton}" AutomationProperties.Name="文件粉碎" AutomationProperties.Description="安全删除文件" TabIndex="18"/>
                            <Button x:Name="SettingsAndSecurityButton" Content="基础设置&amp;安全中心" Click="SettingsAndSecurityButton_Click" Style="{StaticResource NavButton}" AutomationProperties.Name="基础设置和安全中心" AutomationProperties.Description="管理应用设置和安全选项" TabIndex="19"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- 中央内容区 -->
                    <Grid Margin="200,0,0,0" Background="{StaticResource PrimaryBackground}">
                        <!-- 加载指示器 -->
                        <Grid x:Name="LoadingIndicator" Visibility="Collapsed" Background="{StaticResource PrimaryBackground}" Opacity="0.9">
                            <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Ellipse Width="60" Height="60" Stroke="{StaticResource AccentColor}" StrokeThickness="4">
                                    <Ellipse.RenderTransform>
                                        <RotateTransform CenterX="30" CenterY="30"/>
                                    </Ellipse.RenderTransform>
                                    <Ellipse.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard Storyboard="{StaticResource LoadingAnimation}"/>
                                        </EventTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>
                                <TextBlock Text="加载中..." Style="{StaticResource BodyText}" Margin="0,80,0,0" HorizontalAlignment="Center"/>
                            </Grid>
                        </Grid>
                    <!-- 首页概览模块 -->
                    <Grid x:Name="HomePage" Visibility="Visible">
                        <Grid.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                                <TranslateTransform X="0" Y="0"/>
                            </TransformGroup>
                        </Grid.RenderTransform>
                        <!-- 标题 -->
                        <TextBlock Text="首页概览" Style="{StaticResource TitleText}" Margin="20,20,0,0">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="{StaticResource AccentColor}" BlurRadius="10" Opacity="0.8"/>
                            </TextBlock.Effect>
                        </TextBlock>

                        <!-- C盘空间信息 -->
                        <Border Margin="20,60,20,0" Style="{StaticResource CardBorder}">
                            <Grid>
                                <TextBlock Text="C盘空间信息" Style="{StaticResource SubtitleText}" Margin="0,0,0,20"/>
                                <Grid Margin="0,40,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="总容量" Style="{StaticResource CaptionText}"/>
                                        <TextBlock x:Name="TotalSpaceText" Text="0 GB" Style="{StaticResource BodyText}" FontWeight="Bold" Margin="0,5,0,0">
                                            <TextBlock.Effect>
                                                <DropShadowEffect Color="{StaticResource TextPrimary}" BlurRadius="5" Opacity="0.5"/>
                                            </TextBlock.Effect>
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="已用空间" Style="{StaticResource CaptionText}"/>
                                        <TextBlock x:Name="UsedSpaceText" Text="0 GB" Style="{StaticResource BodyText}" FontWeight="Bold" Foreground="{StaticResource WarningColor}" Margin="0,5,0,0">
                                            <TextBlock.Effect>
                                                <DropShadowEffect Color="{StaticResource WarningColor}" BlurRadius="5" Opacity="0.5"/>
                                            </TextBlock.Effect>
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="剩余空间" Style="{StaticResource CaptionText}"/>
                                        <TextBlock x:Name="FreeSpaceText" Text="0 GB" Style="{StaticResource BodyText}" FontWeight="Bold" Foreground="{StaticResource SuccessColor}" Margin="0,5,0,0">
                                            <TextBlock.Effect>
                                                <DropShadowEffect Color="{StaticResource SuccessColor}" BlurRadius="5" Opacity="0.5"/>
                                            </TextBlock.Effect>
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3">
                                        <TextBlock Text="占用占比" Style="{StaticResource CaptionText}"/>
                                        <TextBlock x:Name="UsagePercentageText" Text="0%" Style="{StaticResource BodyText}" FontWeight="Bold" Foreground="{StaticResource AccentColor}" Margin="0,5,0,0">
                                            <TextBlock.Effect>
                                                <DropShadowEffect Color="{StaticResource AccentColor}" BlurRadius="5" Opacity="0.5"/>
                                            </TextBlock.Effect>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                                <!-- 空间进度条 -->
                                <ProgressBar x:Name="SpaceProgressBar" Style="{StaticResource CustomProgressBar}" Margin="0,100,0,0"/>
                            </Grid>
                        </Border>

                        <!-- 系统健康度评分 -->
                        <Border Margin="20,200,20,0" Style="{StaticResource CardBorder}">
                            <Grid>
                                <TextBlock Text="系统健康度" Style="{StaticResource SubtitleText}" Margin="0,0,0,20"/>
                                <Grid Margin="0,40,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock x:Name="HealthScoreText" Text="100" FontSize="48" FontWeight="Bold" Foreground="{StaticResource SuccessColor}">
                                            <TextBlock.Effect>
                                                <DropShadowEffect Color="{StaticResource SuccessColor}" BlurRadius="15" Opacity="0.8"/>
                                            </TextBlock.Effect>
                                        </TextBlock>
                                        <TextBlock Text="健康度评分" Style="{StaticResource CaptionText}" Margin="0,5,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="20,0,0,0">
                                        <TextBlock x:Name="RiskWarningText" Text="系统状态良好，无风险" Style="{StaticResource BodyText}" Foreground="{StaticResource SuccessColor}">
                                            <TextBlock.Effect>
                                                <DropShadowEffect Color="{StaticResource SuccessColor}" BlurRadius="5" Opacity="0.5"/>
                                            </TextBlock.Effect>
                                        </TextBlock>
                                        <TextBlock Text="C盘空间充足，系统运行稳定" Style="{StaticResource CaptionText}" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- 快捷按钮 -->
                        <Grid Margin="20,320,20,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="QuickCleanButton" Content="一键快速清理" Click="QuickCleanButton_Click" Style="{StaticResource PrimaryButton}" Width="200" Height="60" Grid.Column="0" Margin="0,0,20,0" AutomationProperties.Name="一键快速清理" AutomationProperties.Description="快速清理系统垃圾" TabIndex="20">
                                <Button.Effect>
                                    <DropShadowEffect Color="{StaticResource AccentColor}" BlurRadius="10" Opacity="0.8"/>
                                </Button.Effect>
                            </Button>
                            <Button x:Name="SystemOptimizeButton" Content="一键系统优化" Click="SystemOptimizeButton_Click" Style="{StaticResource SecondaryButton}" Width="200" Height="60" Grid.Column="1" Margin="20,0,0,0" AutomationProperties.Name="一键系统优化" AutomationProperties.Description="优化系统性能" TabIndex="21">
                                <Button.Effect>
                                    <DropShadowEffect Color="{StaticResource AccentColor}" BlurRadius="10" Opacity="0.8"/>
                                </Button.Effect>
                            </Button>
                        </Grid>

                        <!-- 近期清理记录 -->
                        <Border Margin="20,400,20,40" Style="{StaticResource CardBorder}">
                            <Grid>
                                <TextBlock Text="近期清理记录" Style="{StaticResource SubtitleText}" Margin="0,0,0,20"/>
                                <DataGrid x:Name="CleaningHistoryDataGrid" Style="{StaticResource CustomDataGrid}" AutoGenerateColumns="False"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  EnableRowVirtualization="True"
                                  EnableColumnVirtualization="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="清理时间" Binding="{Binding Time}" Width="150"/>
                                    <DataGridTextColumn Header="清理类型" Binding="{Binding Type}" Width="120"/>
                                    <DataGridTextColumn Header="释放空间" Binding="{Binding FreedSpace}" Width="100"/>
                                    <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="*"/>
                                </DataGrid.Columns>
                                <DataGrid.Effect>
                                    <DropShadowEffect Color="{StaticResource AccentColor}" BlurRadius="5" Opacity="0.2"/>
                                </DataGrid.Effect>
                            </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
                    
                    <!-- 空间分析模块 -->
                    <Grid x:Name="DiskSpaceAnalyzerPage" Visibility="Collapsed">
                        <Grid.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                                <TranslateTransform X="0" Y="0"/>
                            </TransformGroup>
                        </Grid.RenderTransform>
                        <local:DiskSpaceAnalyzer HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                    </Grid>
                    
                    <!-- 垃圾清理模块 -->
                    <Grid x:Name="JunkCleanPage" Visibility="Collapsed">
                        <Grid.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                                <TranslateTransform X="0" Y="0"/>
                            </TransformGroup>
                        </Grid.RenderTransform>
                        <!-- 标题 -->
                        <TextBlock Text="全量垃圾清理" FontSize="24" FontWeight="Bold" Foreground="#00BFFF" Margin="20,20,0,0"/>
                        
                        <!-- 清理选项 -->
                        <Border Margin="20,60,20,0" Background="#1E1E1E" CornerRadius="8">
                            <Grid Margin="20">
                                <TextBlock Text="清理选项" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,20"/>
                                
                                <!-- 常规系统清理 -->
                                <Expander Header="常规系统清理" FontSize="14" FontWeight="Bold" Foreground="#00BFFF" Margin="0,40,0,0" IsExpanded="True" AutomationProperties.Name="常规系统清理" AutomationProperties.Description="选择要清理的常规系统文件">
                                    <StackPanel Margin="20,10,0,10" AutomationProperties.LabeledBy="{Binding ElementName=RegularSystemCleanupHeader}">
                                        <TextBlock x:Name="RegularSystemCleanupHeader" Text="常规系统清理选项" Visibility="Collapsed"/>
                                        <CheckBox x:Name="RecycleBinCheckBox" Content="回收站" Margin="0,5,0,0" Foreground="#FFFFFF" AutomationProperties.Name="回收站" AutomationProperties.Description="清理回收站中的文件" TabIndex="25"/>
                                        <CheckBox x:Name="TempFilesCheckBox" Content="系统临时文件" Margin="0,5,0,0" Foreground="#FFFFFF" AutomationProperties.Name="系统临时文件" AutomationProperties.Description="清理系统临时文件" TabIndex="26"/>
                                        <CheckBox x:Name="LogFilesCheckBox" Content="日志文件" Margin="0,5,0,0" Foreground="#FFFFFF" AutomationProperties.Name="日志文件" AutomationProperties.Description="清理系统日志文件" TabIndex="27"/>
                                        <CheckBox x:Name="PrefetchCheckBox" Content="预读文件" Margin="0,5,0,0" Foreground="#FFFFFF" AutomationProperties.Name="预读文件" AutomationProperties.Description="清理预读文件" TabIndex="28"/>
                                        <CheckBox x:Name="ThumbnailCacheCheckBox" Content="缩略图缓存" Margin="0,5,0,0" Foreground="#FFFFFF" AutomationProperties.Name="缩略图缓存" AutomationProperties.Description="清理缩略图缓存" TabIndex="29"/>
                                        <CheckBox x:Name="BrowserCacheCheckBox" Content="浏览器缓存/历史记录" Margin="0,5,0,0" Foreground="#FFFFFF" AutomationProperties.Name="浏览器缓存和历史记录" AutomationProperties.Description="清理浏览器缓存和历史记录" TabIndex="30"/>
                                        <CheckBox x:Name="OfficeCacheCheckBox" Content="Office缓存" Margin="0,5,0,0" Foreground="#FFFFFF" AutomationProperties.Name="Office缓存" AutomationProperties.Description="清理Office应用程序缓存" TabIndex="31"/>
                                        <CheckBox x:Name="UpdateCacheCheckBox" Content="系统更新残留包" Margin="0,5,0,0" Foreground="#FFFFFF" AutomationProperties.Name="系统更新残留包" AutomationProperties.Description="清理系统更新残留文件" TabIndex="32"/>
                                    </StackPanel>
                                </Expander>
                                
                                <!-- 深层隐藏目录清理 -->
                                <Expander Header="深层隐藏目录清理" FontSize="14" FontWeight="Bold" Foreground="#00BFFF" Margin="0,200,0,0" IsExpanded="True" AutomationProperties.Name="深层隐藏目录清理" AutomationProperties.Description="选择要清理的深层隐藏目录">
                                    <StackPanel Margin="20,10,0,10" AutomationProperties.LabeledBy="{Binding ElementName=DeepHiddenCleanupHeader}">
                                        <TextBlock x:Name="DeepHiddenCleanupHeader" Text="深层隐藏目录清理选项" Visibility="Collapsed"/>
                                        <CheckBox x:Name="AppDataCheckBox" Content="AppData全目录" Margin="0,5,0,0" Foreground="#FFFFFF" AutomationProperties.Name="AppData全目录" AutomationProperties.Description="清理AppData目录中的缓存文件" TabIndex="33"/>
                                        <CheckBox x:Name="ProgramDataCheckBox" Content="ProgramData公共缓存" Margin="0,5,0,0" Foreground="#FFFFFF" AutomationProperties.Name="ProgramData公共缓存" AutomationProperties.Description="清理ProgramData目录中的公共缓存" TabIndex="34"/>
                                        <CheckBox x:Name="WindowsUpdateCacheCheckBox" Content="Windows更新下载缓存" Margin="0,5,0,0" Foreground="#FFFFFF" AutomationProperties.Name="Windows更新下载缓存" AutomationProperties.Description="清理Windows更新下载的缓存文件" TabIndex="35"/>
                                        <CheckBox x:Name="WindowsOldCheckBox" Content="Windows.old" Margin="0,5,0,0" Foreground="#FFFFFF" AutomationProperties.Name="Windows.old" AutomationProperties.Description="清理Windows.old目录" TabIndex="36"/>
                                        <CheckBox x:Name="ErrorReportsCheckBox" Content="系统错误报告" Margin="0,5,0,0" Foreground="#FFFFFF" AutomationProperties.Name="系统错误报告" AutomationProperties.Description="清理系统错误报告文件" TabIndex="37"/>
                                    </StackPanel>
                                </Expander>
                                
                                <!-- 基础注册表清理 -->
                                <Expander Header="基础注册表清理" FontSize="14" FontWeight="Bold" Foreground="#00BFFF" Margin="0,350,0,0" IsExpanded="True" AutomationProperties.Name="基础注册表清理" AutomationProperties.Description="选择要清理的注册表项">
                                    <StackPanel Margin="20,10,0,10" AutomationProperties.LabeledBy="{Binding ElementName=RegistryCleanupHeader}">
                                        <TextBlock x:Name="RegistryCleanupHeader" Text="基础注册表清理选项" Visibility="Collapsed"/>
                                        <CheckBox x:Name="InvalidRegistryCheckBox" Content="无效注册表项" Margin="0,5,0,0" Foreground="#FFFFFF" AutomationProperties.Name="无效注册表项" AutomationProperties.Description="清理无效的注册表项" TabIndex="38"/>
                                        <CheckBox x:Name="UninstallResidueCheckBox" Content="软件卸载残留" Margin="0,5,0,0" Foreground="#FFFFFF" AutomationProperties.Name="软件卸载残留" AutomationProperties.Description="清理软件卸载后残留的注册表项" TabIndex="39"/>
                                        <CheckBox x:Name="InvalidShortcutsCheckBox" Content="无效快捷方式关联" Margin="0,5,0,0" Foreground="#FFFFFF" AutomationProperties.Name="无效快捷方式关联" AutomationProperties.Description="清理无效的快捷方式关联" TabIndex="40"/>
                                        <CheckBox x:Name="RedundantContextMenuCheckBox" Content="冗余右键菜单" Margin="0,5,0,0" Foreground="#FFFFFF" AutomationProperties.Name="冗余右键菜单" AutomationProperties.Description="清理冗余的右键菜单项" TabIndex="41"/>
                                    </StackPanel>
                                </Expander>
                            </Grid>
                        </Border>
                        
                        <!-- 操作按钮 -->
                        <Grid Margin="20,520,20,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="ScanButton" Content="扫描垃圾" Width="150" Height="50" Background="#00BFFF" Foreground="#FFFFFF" FontSize="14" FontWeight="Bold" Grid.Column="0" Margin="0,0,10,0" Click="ScanButton_Click" AutomationProperties.Name="扫描垃圾" AutomationProperties.Description="扫描系统中的垃圾文件" TabIndex="22"/>
                            <Button x:Name="PreviewButton" Content="预览清理" Width="150" Height="50" Background="#2A2A2A" Foreground="#FFFFFF" FontSize="14" FontWeight="Bold" Grid.Column="1" Margin="10,0,10,0" Click="PreviewButton_Click" AutomationProperties.Name="预览清理" AutomationProperties.Description="预览将要清理的文件" TabIndex="23"/>
                            <Button x:Name="CleanButton" Content="开始清理" Width="150" Height="50" Background="#00BFFF" Foreground="#FFFFFF" FontSize="14" FontWeight="Bold" Grid.Column="2" Margin="10,0,0,0" Click="CleanButton_Click" AutomationProperties.Name="开始清理" AutomationProperties.Description="开始清理垃圾文件" TabIndex="24"/>
                        </Grid>
                        
                        <!-- 清理结果 -->
                        <Border Margin="20,590,20,40" Background="#1E1E1E" CornerRadius="8">
                            <Grid Margin="20">
                                <TextBlock Text="清理结果" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,20"/>
                                <TextBlock x:Name="ScanResultText" Text="请点击扫描按钮开始扫描" FontSize="14" Foreground="#888888"/>
                                <TextBlock x:Name="CleanResultText" Text="" FontSize="14" Foreground="#00FF00" Margin="0,40,0,0"/>
                            </Grid>
                        </Border>
                    </Grid>
                    
                    <!-- 系统优化模块 -->
                    <Grid x:Name="SystemOptimizerPage" Visibility="Collapsed">
                        <Grid.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                                <TranslateTransform X="0" Y="0"/>
                            </TransformGroup>
                        </Grid.RenderTransform>
                        <local:SystemOptimizer HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                    </Grid>
                    
