﻿﻿﻿﻿﻿﻿﻿<Window x:Class="WinShieldOptiPro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WinShieldOptiPro"
        mc:Ignorable="d"
        Title="WinShield OptiPro" Height="768" Width="1366" WindowStyle="SingleBorderWindow" AllowsTransparency="False" Background="#121212">
    <Grid>
        <!-- 主网格 -->

                <!-- 左侧导航栏 -->
                <Grid Margin="0,10,0,10" Width="200" Background="#1A1A1A" HorizontalAlignment="Left">
                    <StackPanel Orientation="Vertical" Margin="0,10,0,0">
                        <Button x:Name="HomeButton" Content="首页" Width="180" Height="40" Foreground="#FFFFFF" Margin="10,0,10,5" Click="HomeButton_Click" Background="#00BFFF" BorderBrush="#00BFFF" BorderThickness="1">
                        </Button>
                        <Button x:Name="HardwareOverviewButton" Content="硬件概览" Width="180" Height="40" Background="#2A2A2A" Foreground="#FFFFFF" Margin="10,0,10,5" Click="HardwareOverviewButton_Click" BorderBrush="Transparent" BorderThickness="1">
                        </Button>
                        <Button x:Name="DiskSpaceAnalyzerButton" Content="空间分析" Width="180" Height="40" Background="#2A2A2A" Foreground="#FFFFFF" Margin="10,0,10,5" Click="DiskSpaceAnalyzerButton_Click" BorderBrush="Transparent" BorderThickness="1">
                        </Button>
                        <Button x:Name="JunkCleanButton" Content="垃圾清理" Width="180" Height="40" Background="#2A2A2A" Foreground="#FFFFFF" Margin="10,0,10,5" Click="JunkCleanButton_Click" BorderBrush="Transparent" BorderThickness="1">
                        </Button>
                        <Button x:Name="SystemOptimizeButtonNav" Content="系统优化" Width="180" Height="40" Background="#2A2A2A" Foreground="#FFFFFF" Margin="10,0,10,5" Click="SystemOptimizeButtonNav_Click" BorderBrush="Transparent" BorderThickness="1">
                        </Button>
                        <Button x:Name="MemoryOptimizerButton" Content="内存优化" Width="180" Height="40" Background="#2A2A2A" Foreground="#FFFFFF" Margin="10,0,10,5" Click="MemoryOptimizerButton_Click" BorderBrush="Transparent" BorderThickness="1">
                        </Button>
                        <Button x:Name="AppDataMonitorButton" Content="AppData监控" Width="180" Height="40" Background="#2A2A2A" Foreground="#FFFFFF" Margin="10,0,10,5" Click="AppDataMonitorButton_Click" BorderBrush="Transparent" BorderThickness="1">
                        </Button>
                        <Button x:Name="SoftwareUninstallerButton" Content="软件卸载" Width="180" Height="40" Background="#2A2A2A" Foreground="#FFFFFF" Margin="10,0,10,5" Click="SoftwareUninstallerButton_Click" BorderBrush="Transparent" BorderThickness="1">
                        </Button>
                        <Button x:Name="SuperSlimmerButton" Content="超级瘦身" Width="180" Height="40" Background="#2A2A2A" Foreground="#FFFFFF" Margin="10,0,10,5" Click="SuperSlimmerButton_Click" BorderBrush="Transparent" BorderThickness="1">
                        </Button>
                        <Button x:Name="SystemToolboxButton" Content="系统工具箱" Width="180" Height="40" Background="#2A2A2A" Foreground="#FFFFFF" Margin="10,0,10,5" Click="SystemToolboxButton_Click" BorderBrush="Transparent" BorderThickness="1">
                        </Button>
                        <Button x:Name="PopupBlockerButton" Content="弹窗拦截" Width="180" Height="40" Background="#2A2A2A" Foreground="#FFFFFF" Margin="10,0,10,5" Click="PopupBlockerButton_Click" BorderBrush="Transparent" BorderThickness="1">
                        </Button>
                        <Button x:Name="FreezeRestoreButton" Content="冰点还原" Width="180" Height="40" Background="#2A2A2A" Foreground="#FFFFFF" Margin="10,0,10,5" Click="FreezeRestoreButton_Click" BorderBrush="Transparent" BorderThickness="1">
                        </Button>
                        <Button x:Name="SystemScannerButton" Content="静默查杀" Width="180" Height="40" Background="#2A2A2A" Foreground="#FFFFFF" Margin="10,0,10,5" Click="SystemScannerButton_Click" BorderBrush="Transparent" BorderThickness="1">
                        </Button>
                        <Button x:Name="FileShredderButton" Content="文件粉碎" Width="180" Height="40" Background="#2A2A2A" Foreground="#FFFFFF" Margin="10,0,10,5" Click="FileShredderButton_Click" BorderBrush="Transparent" BorderThickness="1">
                        </Button>
                        <Button x:Name="SettingsAndSecurityButton" Content="基础设置&amp;安全中心" Width="180" Height="40" Background="#2A2A2A" Foreground="#FFFFFF" Margin="10,0,10,5" Click="SettingsAndSecurityButton_Click" BorderBrush="Transparent" BorderThickness="1">
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- 中央内容区 -->
                <Grid Margin="210,10,10,10" Background="#121212">
                    <!-- 首页概览模块 -->
                    <Grid x:Name="HomePage" Visibility="Visible">
                        <!-- 标题 -->
                        <TextBlock Text="首页概览" FontSize="20" FontWeight="Bold" Foreground="#00BFFF" Margin="20,20,0,0">
                        </TextBlock>

                        <!-- C盘空间信息 -->
                        <Border Margin="20,60,20,0" Background="#1E1E1E" CornerRadius="4" BorderThickness="1" BorderBrush="#00BFFF">
                            <Grid Margin="20">
                                <TextBlock Text="C盘空间信息" FontSize="14" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,20"/>
                                <Grid Margin="0,40,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="总容量" FontSize="12" Foreground="#888888"/>
                                        <TextBlock x:Name="TotalSpaceText" Text="0 GB" FontSize="14" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,5,0,0">
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="已用空间" FontSize="12" Foreground="#888888"/>
                                        <TextBlock x:Name="UsedSpaceText" Text="0 GB" FontSize="14" FontWeight="Bold" Foreground="#FF4500" Margin="0,5,0,0">
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="剩余空间" FontSize="12" Foreground="#888888"/>
                                        <TextBlock x:Name="FreeSpaceText" Text="0 GB" FontSize="14" FontWeight="Bold" Foreground="#00FF00" Margin="0,5,0,0">
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3">
                                        <TextBlock Text="占用占比" FontSize="12" Foreground="#888888"/>
                                        <TextBlock x:Name="UsagePercentageText" Text="0%" FontSize="14" FontWeight="Bold" Foreground="#00BFFF" Margin="0,5,0,0">
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                                <!-- 空间进度条 -->
                                <ProgressBar x:Name="SpaceProgressBar" Height="10" Margin="0,100,0,0" Background="#2A2A2A" BorderThickness="0">
                                </ProgressBar>
                            </Grid>
                        </Border>

                        <!-- 系统健康度评分 -->
                        <Border Margin="20,200,20,0" Background="#1E1E1E" CornerRadius="4" BorderThickness="1" BorderBrush="#00BFFF">
                            <Grid Margin="20">
                                <TextBlock Text="系统健康度" FontSize="14" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,20"/>
                                <Grid Margin="0,40,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock x:Name="HealthScoreText" Text="100" FontSize="36" FontWeight="Bold" Foreground="#00FF00">
                                        </TextBlock>
                                        <TextBlock Text="健康度评分" FontSize="12" Foreground="#888888" Margin="0,5,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="20,0,0,0">
                                        <TextBlock x:Name="RiskWarningText" Text="系统状态良好，无风险" FontSize="14" Foreground="#00FF00">
                                        </TextBlock>
                                        <TextBlock Text="C盘空间充足，系统运行稳定" FontSize="12" Foreground="#888888" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- 快捷按钮 -->
                        <Grid Margin="20,320,20,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="QuickCleanButton" Content="一键快速清理" Width="200" Height="60" Background="#00BFFF" Foreground="#FFFFFF" FontSize="14" FontWeight="Bold" Grid.Column="0" Margin="0,0,20,0" Click="QuickCleanButton_Click" BorderBrush="#00BFFF" BorderThickness="1">
                            </Button>
                            <Button x:Name="SystemOptimizeButton" Content="一键系统优化" Width="200" Height="60" Background="#32CD32" Foreground="#FFFFFF" FontSize="14" FontWeight="Bold" Grid.Column="1" Margin="20,0,0,0" Click="SystemOptimizeButton_Click" BorderBrush="#32CD32" BorderThickness="1">
                            </Button>
                        </Grid>

                        <!-- 近期清理记录 -->
                        <Border Margin="20,400,20,40" Background="#1E1E1E" CornerRadius="4" BorderThickness="1" BorderBrush="#00BFFF">
                            <Grid Margin="20">
                                <TextBlock Text="近期清理记录" FontSize="14" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,20"/>
                                <DataGrid x:Name="CleaningHistoryDataGrid" AutoGenerateColumns="False" Background="#121212" Foreground="#FFFFFF" BorderThickness="0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="清理时间" Binding="{Binding Time}" Width="150"/>
                                        <DataGridTextColumn Header="清理类型" Binding="{Binding Type}" Width="120"/>
                                        <DataGridTextColumn Header="释放空间" Binding="{Binding FreedSpace}" Width="100"/>
                                        <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
                    
                    <!-- 空间分析模块 -->
                    <Grid x:Name="DiskSpaceAnalyzerPage" Visibility="Collapsed">
                        <local:DiskSpaceAnalyzer HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                    </Grid>
                    
                    <!-- 垃圾清理模块 -->
                    <Grid x:Name="JunkCleanPage" Visibility="Collapsed">
                        <!-- 标题 -->
                        <TextBlock Text="全量垃圾清理" FontSize="24" FontWeight="Bold" Foreground="#00BFFF" Margin="20,20,0,0"/>
                        
                        <!-- 清理选项 -->
                        <Border Margin="20,60,20,0" Background="#1E1E1E" CornerRadius="8">
                            <Grid Margin="20">
                                <TextBlock Text="清理选项" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,20"/>
                                
                                <!-- 常规系统清理 -->
                                <Expander Header="常规系统清理" FontSize="14" FontWeight="Bold" Foreground="#00BFFF" Margin="0,40,0,0" IsExpanded="True">
                                    <StackPanel Margin="20,10,0,10">
                                        <CheckBox x:Name="RecycleBinCheckBox" Content="回收站" Margin="0,5,0,0" Foreground="#FFFFFF"/>
                                        <CheckBox x:Name="TempFilesCheckBox" Content="系统临时文件" Margin="0,5,0,0" Foreground="#FFFFFF"/>
                                        <CheckBox x:Name="LogFilesCheckBox" Content="日志文件" Margin="0,5,0,0" Foreground="#FFFFFF"/>
                                        <CheckBox x:Name="PrefetchCheckBox" Content="预读文件" Margin="0,5,0,0" Foreground="#FFFFFF"/>
                                        <CheckBox x:Name="ThumbnailCacheCheckBox" Content="缩略图缓存" Margin="0,5,0,0" Foreground="#FFFFFF"/>
                                        <CheckBox x:Name="BrowserCacheCheckBox" Content="浏览器缓存/历史记录" Margin="0,5,0,0" Foreground="#FFFFFF"/>
                                        <CheckBox x:Name="OfficeCacheCheckBox" Content="Office缓存" Margin="0,5,0,0" Foreground="#FFFFFF"/>
                                        <CheckBox x:Name="UpdateCacheCheckBox" Content="系统更新残留包" Margin="0,5,0,0" Foreground="#FFFFFF"/>
                                    </StackPanel>
                                </Expander>
                                
                                <!-- 深层隐藏目录清理 -->
                                <Expander Header="深层隐藏目录清理" FontSize="14" FontWeight="Bold" Foreground="#00BFFF" Margin="0,200,0,0" IsExpanded="True">
                                    <StackPanel Margin="20,10,0,10">
                                        <CheckBox x:Name="AppDataCheckBox" Content="AppData全目录" Margin="0,5,0,0" Foreground="#FFFFFF"/>
                                        <CheckBox x:Name="ProgramDataCheckBox" Content="ProgramData公共缓存" Margin="0,5,0,0" Foreground="#FFFFFF"/>
                                        <CheckBox x:Name="WindowsUpdateCacheCheckBox" Content="Windows更新下载缓存" Margin="0,5,0,0" Foreground="#FFFFFF"/>
                                        <CheckBox x:Name="WindowsOldCheckBox" Content="Windows.old" Margin="0,5,0,0" Foreground="#FFFFFF"/>
                                        <CheckBox x:Name="ErrorReportsCheckBox" Content="系统错误报告" Margin="0,5,0,0" Foreground="#FFFFFF"/>
                                    </StackPanel>
                                </Expander>
                                
                                <!-- 基础注册表清理 -->
                                <Expander Header="基础注册表清理" FontSize="14" FontWeight="Bold" Foreground="#00BFFF" Margin="0,350,0,0" IsExpanded="True">
                                    <StackPanel Margin="20,10,0,10">
                                        <CheckBox x:Name="InvalidRegistryCheckBox" Content="无效注册表项" Margin="0,5,0,0" Foreground="#FFFFFF"/>
                                        <CheckBox x:Name="UninstallResidueCheckBox" Content="软件卸载残留" Margin="0,5,0,0" Foreground="#FFFFFF"/>
                                        <CheckBox x:Name="InvalidShortcutsCheckBox" Content="无效快捷方式关联" Margin="0,5,0,0" Foreground="#FFFFFF"/>
                                        <CheckBox x:Name="RedundantContextMenuCheckBox" Content="冗余右键菜单" Margin="0,5,0,0" Foreground="#FFFFFF"/>
                                    </StackPanel>
                                </Expander>
                            </Grid>
                        </Border>
                        
                        <!-- 操作按钮 -->
                        <Grid Margin="20,520,20,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="ScanButton" Content="扫描垃圾" Width="150" Height="50" Background="#00BFFF" Foreground="#FFFFFF" FontSize="14" FontWeight="Bold" Grid.Column="0" Margin="0,0,10,0" Click="ScanButton_Click"/>
                            <Button x:Name="PreviewButton" Content="预览清理" Width="150" Height="50" Background="#2A2A2A" Foreground="#FFFFFF" FontSize="14" FontWeight="Bold" Grid.Column="1" Margin="10,0,10,0" Click="PreviewButton_Click"/>
                            <Button x:Name="CleanButton" Content="开始清理" Width="150" Height="50" Background="#00BFFF" Foreground="#FFFFFF" FontSize="14" FontWeight="Bold" Grid.Column="2" Margin="10,0,0,0" Click="CleanButton_Click"/>
                        </Grid>
                        
                        <!-- 清理结果 -->
                        <Border Margin="20,590,20,40" Background="#1E1E1E" CornerRadius="8">
                            <Grid Margin="20">
                                <TextBlock Text="清理结果" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,20"/>
                                <TextBlock x:Name="ScanResultText" Text="请点击扫描按钮开始扫描" FontSize="14" Foreground="#888888"/>
                                <TextBlock x:Name="CleanResultText" Text="" FontSize="14" Foreground="#00FF00" Margin="0,40,0,0"/>
                            </Grid>
                        </Border>
                    </Grid>
                    
                    <!-- 系统优化模块 -->
                    <Grid x:Name="SystemOptimizerPage" Visibility="Collapsed">
                        <local:SystemOptimizer HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                    </Grid>
                    
                    <!-- AppData监控模块 -->
                    <Grid x:Name="AppDataMonitorPage" Visibility="Collapsed">
                        <local:AppDataMonitor HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                    </Grid>
                    
                    <!-- 软件卸载模块 -->
                    <Grid x:Name="SoftwareUninstallerPage" Visibility="Collapsed">
                        <local:SoftwareUninstaller HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                    </Grid>
                    
                    <!-- 超级瘦身模块 -->
                    <Grid x:Name="SuperSlimmerPage" Visibility="Collapsed">
                        <local:SuperSlimmer HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                    </Grid>
                    
                    <!-- 内存优化模块 -->
                    <Grid x:Name="MemoryOptimizerPage" Visibility="Collapsed">
                        <local:MemoryOptimizer HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                    </Grid>
                    
                    <!-- 硬件概览模块 -->
                    <Grid x:Name="HardwareOverviewPage" Visibility="Collapsed">
                        <local:HardwareOverview HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                    </Grid>
                    
                    <!-- 系统工具箱模块 -->
                    <Grid x:Name="SystemToolboxPage" Visibility="Collapsed">
                        <local:SystemToolbox HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                    </Grid>
                    
                    <!-- 系统静默查杀模块 -->
                    <Grid x:Name="SystemScannerPage" Visibility="Collapsed">
                        <local:SystemScanner HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                    </Grid>
                    
                    <!-- 文件粉碎模块 -->
                    <Grid x:Name="FileShredderPage" Visibility="Collapsed">
                        <local:FileShredder HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                    </Grid>
                    
                    <!-- 弹窗拦截模块 -->
                    <Grid x:Name="PopupBlockerPage" Visibility="Collapsed">
                        <local:PopupBlocker HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                    </Grid>
                    
                    <!-- 冰点还原模块 -->
                    <Grid x:Name="FreezeRestorePage" Visibility="Collapsed">
                        <local:FreezeRestore HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                    </Grid>
                    
                    <!-- 基础设置&安全中心模块 -->
                    <Grid x:Name="SettingsAndSecurityPage" Visibility="Collapsed">
                        <local:SettingsAndSecurity HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                    </Grid>
                </Grid>

                <!-- 底部状态栏 -->
                <Border Height="40" Background="#1E1E1E" VerticalAlignment="Bottom">
                    <Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="20,0,0,0">
                            <TextBlock Text="CPU: 0%" FontSize="12" Foreground="#888888" Margin="0,0,20,0"/>
                            <TextBlock Text="内存: 0%" FontSize="12" Foreground="#888888" Margin="0,0,20,0"/>
                            <TextBlock Text="C盘: 0%" FontSize="12" Foreground="#888888"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
                            <Button Content="日志" Width="60" Height="25" Background="#2A2A2A" Foreground="#FFFFFF" BorderThickness="0" Margin="0,0,10,0"/>
                            <Button Content="修复" Width="60" Height="25" Background="#2A2A2A" Foreground="#FFFFFF" BorderThickness="0"/>
                        </StackPanel>
                    </Grid>
                </Border>
    </Grid>
</Window>